#!/usr/bin/env bash
set -euo pipefail

if [[ "${BYPASS_SECRET_SCAN:-0}" == "1" ]]; then
  exit 0
fi

if command -v python >/dev/null 2>&1; then
  python -X utf8 tools/security/check_staged_secrets.py
elif command -v py >/dev/null 2>&1; then
  py -3 -X utf8 tools/security/check_staged_secrets.py
else
  echo "[secret-guard] Python not found. Cannot run staged secret scan."
  echo "[secret-guard] Install Python or run tools/security/check_staged_secrets.py manually."
  exit 1
fi
