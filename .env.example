# 环境变量配置文件
# 复制此文件为 .env 并填写实际值

# MySQL配置
MYSQL_PASSWORD=root

# RabbitMQ配置
RABBITMQ_PASSWORD=admin123

# JWT配置 (生产环境请使用强随机字符串)
JWT_SECRET=videotomd-secret-key-please-change-in-production

# 文件存储路径
STORAGE_BASE_PATH=./uploads

# DeepSeek API Key (Python Worker使用)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
