# Environment variables template
# Copy to .env and fill values

# MySQL
MYSQL_PASSWORD=root

# RabbitMQ
RABBITMQ_PASSWORD=admin123

# JWT (change in production)
JWT_SECRET=videotomd-secret-key-please-change-in-production

# Android mobile API base URL (recommended public entry)
# Either of the following env vars can be used during Gradle build.
# Preferred when using Gradle env-style property injection:
ORG_GRADLE_PROJECT_mobileApiBaseUrl=https://216d0ee2.r9.cpolar.cn
# Alternative custom app env vars also supported by app/build.gradle.kts:
MOBILE_APP_API_BASE_URL=https://216d0ee2.r9.cpolar.cn
# MOBILE_API_BASE_URL is intentionally not used by app/build.gradle.kts anymore to avoid stale shell overrides

# Storage path
STORAGE_BASE_PATH=./uploads

# DeepSeek API Key (Python worker)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# DeepSeek production concurrency profile (from 2026-02-16 core benchmark)
MODULE2_DEEPSEEK_CONCURRENCY_INITIAL=56
MODULE2_DEEPSEEK_CONCURRENCY_MIN=8
MODULE2_DEEPSEEK_CONCURRENCY_MAX=64
MODULE2_DEEPSEEK_CONCURRENCY_INCREASE_STEP=1
MODULE2_DEEPSEEK_CONCURRENCY_WINDOW_SIZE=30

# Scenario-level inflight limits
MODULE2_SEMANTIC_SEGMENT_BATCH_MAX_CONCURRENCY=48
MODULE2_MARKDOWN_SECTION_MAX_INFLIGHT=56
MODULE2_KC_MULTI_CHUNK_MAX_INFLIGHT=48
MODULE2_SHARED_FRAME_REGISTRY_MAX_MB=384
# Stage1 步骤并发上限（0=不限制）
TRANSCRIPT_NODE_MAX_INFLIGHT=0

# WeCom Bot callback & send-message config
WECOM_LISTEN_HOST=0.0.0.0
WECOM_LISTEN_PORT=5000
WECOM_CALLBACK_PATH=/wechat/callback
WECOM_CALLBACK_TOKEN=videoToMarkdown
WECOM_ENCODING_AES_KEY=replace-with-your-encoding-aes-key
WECOM_RECEIVE_ID=
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=
WECOM_MAX_RETRIES=2
WECOM_TASK_POLL_INTERVAL_SEC=10
WECOM_RETRY_BACKOFF_BASE_SEC=30
WECOM_MSG_DEDUPE_TTL_SEC=600
WECOM_HTTP_TIMEOUT_SEC=8
ORCHESTRATOR_API_URL=http://127.0.0.1:8080/api
