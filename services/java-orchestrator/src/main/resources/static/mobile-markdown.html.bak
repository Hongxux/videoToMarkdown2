<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>移动端 Markdown 查看器</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
    <style>
        :root {
            --bg: #f1f5f9;
            --card: #ffffff;
            --text: #0f172a;
            --muted: #475569;
            --border: #cbd5e1;
            --primary: #4f46e5;
            --primary-soft: #e0e7ff;
            --success: #059669;
            --warning: #d97706;
            --danger: #dc2626;
            --space-2: 8px;
            --space-3: 12px;
            --space-4: 16px;
            --space-5: 20px;
            --radius: 14px;
            --bottom-nav-h: 74px;
            --font-body: "PingFang SC", "Microsoft YaHei", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-body);
        }

        .app {
            max-width: 980px;
            margin: 0 auto;
            min-height: 100dvh;
            position: relative;
            padding-bottom: var(--bottom-nav-h);
        }

        .app-content {
            height: calc(100dvh - var(--bottom-nav-h));
            position: relative;
            padding: var(--space-3);
            overflow: hidden;
        }

        .app-view {
            position: absolute;
            inset: var(--space-3);
            overflow: auto;
            opacity: 0;
            transform: translateY(12px);
            pointer-events: none;
            transition: opacity 0.22s ease, transform 0.22s ease;
        }

        .app-view.active {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }

        .panel {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: 0 8px 22px rgba(15, 23, 42, 0.07);
            overflow: hidden;
            min-height: 100%;
            display: flex;
            flex-direction: column;
        }

        .header {
            padding: 12px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
        }

        .header h1,
        .header h2 {
            margin: 0;
            font-size: 16px;
        }

        .toolbar {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .btn {
            border: 1px solid var(--border);
            background: #fff;
            color: var(--text);
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 14px;
            cursor: pointer;
            min-height: 44px;
        }

        .btn-primary {
            background: var(--primary);
            border-color: var(--primary);
            color: #fff;
        }

        .status-tip {
            color: var(--muted);
            font-size: 13px;
            padding: 0 12px 12px;
        }

        .task-list {
            padding: 10px;
            display: grid;
            gap: 8px;
            flex: 1;
            min-height: 0;
            overflow: auto;
        }

        .task-item {
            width: 100%;
            text-align: left;
            border: 1px solid var(--border);
            background: #fff;
            border-radius: 10px;
            padding: 10px;
            cursor: pointer;
            display: grid;
            gap: 4px;
            min-height: 76px;
        }

        .task-item.active {
            border-color: var(--primary);
            background: #eff6ff;
        }

        .task-title {
            font-size: 14px;
            font-weight: 600;
            line-height: 1.35;
            word-break: break-all;
        }

        .task-meta {
            color: var(--muted);
            font-size: 12px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .badge {
            display: inline-block;
            border-radius: 999px;
            padding: 2px 8px;
            font-size: 12px;
            font-weight: 600;
            color: #fff;
        }

        .badge-queued { background: var(--warning); }
        .badge-processing { background: var(--primary); }
        .badge-completed { background: var(--success); }
        .badge-failed,
        .badge-cancelled { background: var(--danger); }

        .viewer-title {
            font-size: 14px;
            color: var(--muted);
            padding: 8px 12px 0;
            word-break: break-all;
        }

        .viewer-layout {
            padding: 8px 12px 12px;
            display: grid;
            grid-template-columns: 1fr;
            gap: 10px;
            flex: 1;
            min-height: 0;
        }

        .markdown-body {
            padding: 12px;
            font-size: 15px;
            line-height: 1.75;
            word-break: break-word;
            border: 1px solid var(--border);
            border-radius: 10px;
            background: #fff;
            min-height: 100%;
        }

        .markdown-body h1,
        .markdown-body h2,
        .markdown-body h3 {
            margin: 1rem 0 0.5rem;
            line-height: 1.4;
        }

        .markdown-body pre {
            background: #0f172a;
            color: #e5e7eb;
            padding: 10px;
            border-radius: 8px;
            overflow: auto;
        }

        .markdown-body code {
            font-family: Consolas, Menlo, Monaco, monospace;
            font-size: 0.9em;
        }

        .markdown-body blockquote {
            margin: 0.8rem 0;
            border-left: 4px solid #93c5fd;
            background: #eff6ff;
            padding: 8px 12px;
            border-radius: 6px;
        }

        .markdown-body img,
        .markdown-body video {
            max-width: 100%;
            border-radius: 8px;
            margin: 8px 0;
            background: #000;
        }

        .empty {
            padding: 20px 12px;
            color: var(--muted);
            text-align: center;
        }

        .error {
            color: var(--danger);
            white-space: pre-wrap;
        }

        .bottom-nav {
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            height: var(--bottom-nav-h);
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 8px;
            align-items: center;
            padding: 8px max(12px, env(safe-area-inset-left)) calc(8px + env(safe-area-inset-bottom)) max(12px, env(safe-area-inset-right));
            background: rgba(248, 250, 252, 0.94);
            border-top: 1px solid var(--border);
            backdrop-filter: blur(8px);
            z-index: 100;
            max-width: 980px;
            margin: 0 auto;
        }

        .tab-btn {
            min-height: 44px;
            border: 1px solid transparent;
            background: transparent;
            color: #475569;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
        }

        .tab-btn.active {
            color: #ffffff;
            background: var(--primary);
            border-color: var(--primary);
            box-shadow: 0 8px 20px rgba(79, 70, 229, 0.26);
        }

        .quick-fab-wrap {
            position: fixed;
            right: 14px;
            bottom: calc(var(--bottom-nav-h) + 12px);
            z-index: 120;
            display: grid;
            justify-items: end;
            gap: 10px;
        }

        .quick-fab {
            border: 1px solid #1d4ed8;
            background: #2563eb;
            color: #fff;
            border-radius: 50%;
            width: 52px;
            height: 52px;
            font-size: 26px;
            font-weight: 500;
            line-height: 1;
            cursor: pointer;
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.35);
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .quick-fab.active {
            background: #1d4ed8;
        }

        .quick-fab-menu {
            min-width: 148px;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.18);
            padding: 6px;
            display: none;
            grid-auto-rows: min-content;
            gap: 4px;
            margin-bottom: 60px;
        }

        .quick-fab-menu.open {
            display: grid;
        }

        .quick-fab-item {
            border: 1px solid transparent;
            border-radius: 8px;
            background: #fff;
            color: var(--text);
            font-size: 13px;
            padding: 8px 10px;
            text-align: left;
            cursor: pointer;
            min-height: 44px;
        }

        .quick-fab-item:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
        }

        .outline-title {
            padding: 10px 12px;
            font-size: 13px;
            color: var(--muted);
            border-bottom: 1px solid var(--border);
        }

        .outline-list {
            min-height: 0;
            overflow: auto;
            padding: 10px;
            display: grid;
            gap: 6px;
        }

        .outline-list-page {
            flex: 1;
            padding: 12px;
        }

        .outline-item {
            display: flex;
            align-items: center;
            border: 1px solid transparent;
            border-radius: 10px;
            min-height: 44px;
            padding: 8px 10px;
            text-decoration: none;
            color: var(--text);
            font-size: 14px;
            line-height: 1.4;
            word-break: break-word;
        }

        .outline-item:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
        }

        .outline-item.active {
            background: #dbeafe;
            border-color: #93c5fd;
            color: #1d4ed8;
            font-weight: 600;
        }

        .outline-level-2 { padding-left: 20px; }
        .outline-level-3 { padding-left: 30px; }
        .outline-level-4 { padding-left: 40px; }

        .paragraph-list {
            display: grid;
            gap: 10px;
        }

        .paragraph-card {
            border: 1px solid var(--border);
            border-radius: 10px;
            background: #fff;
            padding: 10px;
            display: grid;
            gap: 8px;
        }

        .paragraph-preview {
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 8px;
            background: #f8fafc;
        }

        .paragraph-menu-row {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 8px;
        }

        .paragraph-comment-badge {
            min-width: 26px;
            height: 24px;
            border: 1px solid #60a5fa;
            border-radius: 999px;
            background: #eff6ff;
            color: #1d4ed8;
            padding: 0 8px;
            font-size: 12px;
            font-weight: 600;
            line-height: 22px;
            cursor: pointer;
            text-align: center;
        }

        .paragraph-menu-wrap {
            position: relative;
        }

        .paragraph-plus-btn {
            width: 24px;
            height: 24px;
            border: 1px solid #cbd5e1;
            background: #ffffff;
            color: #334155;
            border-radius: 4px;
            line-height: 1;
            font-size: 16px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0;
        }

        .paragraph-plus-btn:hover {
            background: #f1f5f9;
            border-color: #94a3b8;
        }

        .paragraph-menu {
            position: absolute;
            top: calc(100% + 6px);
            right: 0;
            min-width: 132px;
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 8px;
            box-shadow: 0 6px 18px rgba(15, 23, 42, 0.15);
            padding: 4px;
            display: none;
            z-index: 50;
        }

        .paragraph-menu.open {
            display: grid;
            gap: 2px;
        }

        .paragraph-menu-item {
            text-align: left;
            border: 1px solid transparent;
            background: #fff;
            color: var(--text);
            border-radius: 6px;
            padding: 6px 8px;
            font-size: 12px;
            cursor: pointer;
        }

        .paragraph-menu-item:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
        }

        .paragraph-menu-item.favorite {
            color: #b45309;
            background: #fffbeb;
            border-color: #fde68a;
        }

        .paragraph-textarea {
            width: 100%;
            min-height: 130px;
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 8px;
            font-size: 14px;
            line-height: 1.5;
            font-family: Consolas, Menlo, Monaco, monospace;
            resize: vertical;
        }

        .paragraph-note {
            font-size: 12px;
            color: #92400e;
            background: #fffbeb;
            border: 1px solid #fde68a;
            border-radius: 8px;
            padding: 6px 8px;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .comment-modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.35);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s ease;
            z-index: 110;
        }

        .comment-modal-overlay.open {
            opacity: 1;
            pointer-events: auto;
        }

        .comment-modal {
            position: fixed;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%) scale(0.96);
            width: min(640px, calc(100vw - 24px));
            max-height: min(82vh, 760px);
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 12px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.28);
            z-index: 111;
            display: grid;
            grid-template-rows: auto 1fr auto;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s ease, transform 0.2s ease;
            overflow: hidden;
        }

        .comment-modal.open {
            opacity: 1;
            pointer-events: auto;
            transform: translate(-50%, -50%) scale(1);
        }

        .comment-modal-header {
            padding: 10px 12px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            font-size: 14px;
            font-weight: 600;
        }

        .comment-modal-close {
            border: 1px solid var(--border);
            border-radius: 8px;
            background: #fff;
            padding: 4px 8px;
            font-size: 12px;
            cursor: pointer;
        }

        .comment-modal-body {
            padding: 10px 12px;
            overflow: auto;
            display: grid;
            gap: 10px;
            align-content: start;
        }

        .comment-item {
            border: 1px solid #dbe2ef;
            border-radius: 10px;
            background: #f8fafc;
            padding: 8px;
            display: grid;
            gap: 8px;
        }

        .comment-item textarea {
            width: 100%;
            min-height: 78px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding: 8px;
            font-size: 13px;
            line-height: 1.45;
            font-family: "PingFang SC", "Microsoft YaHei", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            resize: vertical;
        }

        .comment-item-toolbar {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
        }

        .comment-modal-footer {
            padding: 10px 12px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            gap: 8px;
            flex-wrap: wrap;
        }

        .undo-toast {
            position: fixed;
            left: 50%;
            bottom: 88px;
            transform: translateX(-50%) translateY(20px);
            background: #0f172a;
            color: #fff;
            border-radius: 10px;
            padding: 10px 12px;
            display: flex;
            align-items: center;
            gap: 12px;
            z-index: 130;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s ease, transform 0.2s ease;
            max-width: calc(100vw - 24px);
        }

        .undo-toast.open {
            opacity: 1;
            pointer-events: auto;
            transform: translateX(-50%) translateY(0);
        }

        .undo-toast button {
            border: 1px solid #60a5fa;
            background: #1d4ed8;
            color: #fff;
            border-radius: 8px;
            padding: 4px 10px;
            font-size: 12px;
            cursor: pointer;
        }

        @media (min-width: 980px) {
            .app {
                grid-template-columns: 360px 1fr;
                align-items: start;
            }

            .task-list {
                max-height: calc(100vh - 190px);
            }

            .viewer-layout {
                grid-template-columns: minmax(0, 1fr);
                align-items: start;
            }
        }
    </style>
</head>
<body>
<div class="app">
    <main class="app-content">
        <section class="app-view active" id="viewTasks" data-tab="tasks">
            <section class="panel">
                <div class="header">
                    <h1>任务列表</h1>
                    <div class="toolbar">
                        <button class="btn btn-primary" id="refreshBtn">刷新</button>
                    </div>
                </div>
                <div class="status-tip" id="taskSummary">加载中...</div>
                <div class="task-list" id="taskList"></div>
            </section>
        </section>

        <section class="app-view" id="viewReading" data-tab="reading">
            <section class="panel">
                <div class="header">
                    <h2>Markdown 阅读</h2>
                    <div class="toolbar">
                        <button class="btn" id="reloadCurrentBtn">重载当前文档</button>
                        <button class="btn" id="toggleEditModeBtn">逐行编辑</button>
                        <button class="btn" id="renameTaskBtn">重命名任务</button>
                        <button class="btn" id="exportTaskBtn">导出ZIP</button>
                    </div>
                </div>
                <div class="viewer-title" id="viewerTitle">请选择一个任务</div>
                <div class="viewer-layout">
                    <article class="markdown-body" id="markdownBody">
                        <div class="empty">请选择任务查看 Markdown 内容。</div>
                    </article>
                </div>
            </section>
        </section>

        <section class="app-view" id="viewOutline" data-tab="outline">
            <section class="panel panel-outline">
                <div class="header">
                    <h2>文档大纲</h2>
                </div>
                <div class="outline-list outline-list-page" id="outlineList">
                    <div class="empty">暂无可跳转标题</div>
                </div>
            </section>
        </section>
    </main>

    <nav class="bottom-nav" id="bottomNav" aria-label="主导航">
        <button class="tab-btn active" id="tabBtnTasks" data-tab-btn="tasks" type="button">任务列表</button>
        <button class="tab-btn" id="tabBtnReading" data-tab-btn="reading" type="button">阅读</button>
        <button class="tab-btn" id="tabBtnOutline" data-tab-btn="outline" type="button">大纲</button>
    </nav>
</div>
<div class="quick-fab-wrap" id="quickFabWrap">
    <div class="quick-fab-menu" id="quickFabMenu">
        <button class="quick-fab-item" id="quickActionOutline" type="button">打开大纲</button>
        <button class="quick-fab-item" id="quickActionEdit" type="button">开启逐行编辑</button>
        <button class="quick-fab-item" id="quickActionExport" type="button">导出ZIP</button>
    </div>
    <button class="quick-fab" id="quickFabBtn" type="button">+</button>
</div>
<div class="comment-modal-overlay" id="commentModalOverlay"></div>
<section class="comment-modal" id="commentModal">
    <div class="comment-modal-header">
        <span id="commentModalTitle">行批注</span>
        <button class="comment-modal-close" id="commentModalCloseBtn" type="button">关闭</button>
    </div>
    <div class="comment-modal-body" id="commentModalBody">
        <div class="empty">暂无批注</div>
    </div>
    <div class="comment-modal-footer">
        <button class="btn" id="commentModalAddBtn" type="button">新增批注</button>
        <button class="btn btn-primary" id="commentModalSaveBtn" type="button">保存批注</button>
    </div>
</section>
<div class="undo-toast" id="undoToast">
    <span id="undoToastText">已删除</span>
    <button id="undoToastBtn" type="button">撤回</button>
</div>

<script src="https://cdn.jsdelivr.net/npm/markdown-it/dist/markdown-it.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/markdown-it-katex@2.0.3/dist/markdown-it-katex.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.1.7/dist/purify.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>

<script>
    const API_BASE = `${window.location.origin}/api/mobile`;
    const state = {
        tasks: [],
        currentTaskId: null,
        currentTaskTitle: '',
        currentMarkdownPath: null,
        currentMarkdownBaseDir: null,
        currentMarkdownRaw: '',
        mdEngine: null,
        outlineVisible: false,
        editMode: false,
        paragraphBlocks: [],
        paragraphEditingIndex: -1,
        paragraphDraftText: '',
        paragraphMenuIndex: -1,
        paragraphMeta: { favorites: {}, comments: {} },
        commentModalVisible: false,
        commentModalParagraphIndex: -1,
        commentModalDrafts: [],
        quickFabOpen: false,
        touchGesture: null,
        lastTapAt: 0,
        lastTapIndex: -1,
        undoDeleteSnapshot: null,
        undoDeleteTimeoutId: null,
        mediaPressTimer: null,
        pinchStartDistance: 0,
        pinchTriggered: false,
        outlineHeadings: [],
        scrollSpyHandler: null,
        activeOutlineId: '',
    };
    let paragraphMetaSaveQueue = Promise.resolve();

    function isAbsoluteUrl(url) {
        if (!url) return false;
        return /^(https?:|data:|blob:|mailto:|tel:|#)/i.test(url);
    }

    function getExt(path) {
        if (!path) return '';
        const clean = String(path).split('?')[0].split('#')[0];
        const idx = clean.lastIndexOf('.');
        return idx >= 0 ? clean.slice(idx + 1).toLowerCase() : '';
    }

    function isImagePath(path) {
        return ['png', 'jpg', 'jpeg', 'gif', 'webp', 'bmp', 'svg'].includes(getExt(path));
    }

    function isVideoPath(path) {
        return ['mp4', 'webm', 'mov', 'm4v'].includes(getExt(path));
    }

    function isMarkdownPath(path) {
        const ext = getExt(path);
        return ext === 'md' || ext === 'markdown';
    }

    function buildAssetUrl(taskId, relativePath) {
        return `${API_BASE}/tasks/${encodeURIComponent(taskId)}/asset?path=${encodeURIComponent(relativePath)}`;
    }

    function buildStatusClass(status) {
        const lower = String(status || '').toLowerCase();
        if (lower === 'processing') return 'badge-processing';
        if (lower === 'completed') return 'badge-completed';
        if (lower === 'failed') return 'badge-failed';
        if (lower === 'cancelled') return 'badge-cancelled';
        return 'badge-queued';
    }

    function formatTime(isoText) {
        if (!isoText) return '';
        const date = new Date(isoText);
        if (Number.isNaN(date.getTime())) return isoText;
        return date.toLocaleString();
    }

    function loadParagraphMeta() {
        return { favorites: {}, comments: {} };
    }

    async function fetchTaskMetaFromServer(pathHint) {
        if (!state.currentTaskId) {
            return null;
        }
        const query = pathHint ? `?path=${encodeURIComponent(pathHint)}` : '';
        const resp = await fetch(`${API_BASE}/tasks/${encodeURIComponent(state.currentTaskId)}/meta${query}`);
        if (!resp.ok) {
            const text = await resp.text();
            throw new Error(text || `HTTP ${resp.status}`);
        }
        return resp.json();
    }

    async function saveTaskMetaToServer(update) {
        if (!state.currentTaskId) {
            throw new Error('未选择任务');
        }
        const pathHint = buildSavePathHint();
        const payload = {
            path: pathHint,
            taskTitle: update && Object.prototype.hasOwnProperty.call(update, 'taskTitle') ? update.taskTitle : undefined,
            favorites: update && update.favorites ? update.favorites : state.paragraphMeta.favorites,
            comments: update && update.comments ? update.comments : state.paragraphMeta.comments,
        };
        const resp = await fetch(`${API_BASE}/tasks/${encodeURIComponent(state.currentTaskId)}/meta`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });
        if (!resp.ok) {
            const text = await resp.text();
            throw new Error(text || `HTTP ${resp.status}`);
        }
        return resp.json();
    }

    async function refreshParagraphMetaFromServer() {
        try {
            const meta = await fetchTaskMetaFromServer(buildSavePathHint());
            state.paragraphMeta = {
                favorites: meta && meta.favorites ? meta.favorites : {},
                comments: meta && meta.comments ? meta.comments : {},
            };
            if (meta && typeof meta.taskTitle === 'string' && meta.taskTitle.trim()) {
                state.currentTaskTitle = meta.taskTitle.trim();
            }
        } catch (error) {
            console.warn('加载任务元数据失败', error);
            state.paragraphMeta = { favorites: {}, comments: {} };
        }
    }

    function syncTaskTitleFromState(newTitle) {
        if (!state.currentTaskId || !newTitle) return;
        const item = (state.tasks || []).find((task) => task.taskId === state.currentTaskId);
        if (item) {
            item.title = newTitle;
        }
    }

    function refreshViewerTitle() {
        const viewerTitle = document.getElementById('viewerTitle');
        if (!viewerTitle) return;
        if (!state.currentTaskId) {
            viewerTitle.textContent = '请选择一个任务';
            return;
        }
        const title = state.currentTaskTitle || state.currentTaskId;
        const path = state.currentMarkdownPath || '';
        viewerTitle.textContent = path ? `${title} | ${path}` : title;
    }

    async function retryAsync(fn, maxRetries) {
        let lastError = null;
        const retries = Number.isFinite(maxRetries) ? Math.max(0, maxRetries) : 0;
        for (let attempt = 0; attempt <= retries; attempt += 1) {
            try {
                return await fn();
            } catch (error) {
                lastError = error;
                if (attempt >= retries) {
                    break;
                }
                await new Promise((resolve) => setTimeout(resolve, 250 * (attempt + 1)));
            }
        }
        throw lastError || new Error('重试失败');
    }

    function escapeHtml(raw) {
        return String(raw || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function splitMarkdownIntoParagraphBlocks(markdown) {
        const text = String(markdown || '');
        if (text.length === 0) return [];
        return text.split(/\r?\n/).map((line, idx) => ({ id: `l-${idx + 1}`, text: line }));
    }

    function joinParagraphBlocks(blocks) {
        return (blocks || []).map((block) => String(block.text || '')).join('\n');
    }

    async function saveMarkdownToServer(markdownText) {
        const relativePath = buildSavePathHint();
        const payload = {
            markdown: markdownText,
            path: relativePath,
        };
        const resp = await fetch(`${API_BASE}/tasks/${encodeURIComponent(state.currentTaskId)}/markdown`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });
        if (!resp.ok) {
            const text = await resp.text();
            throw new Error(text || `HTTP ${resp.status}`);
        }
        return resp.json();
    }

    function buildSavePathHint() {
        const fullPath = state.currentMarkdownPath || '';
        const baseDir = state.currentMarkdownBaseDir || '';
        if (!fullPath || !baseDir) {
            return '';
        }
        const normFull = String(fullPath).replace(/\\/g, '/');
        const normBase = String(baseDir).replace(/\\/g, '/').replace(/\/+$/, '');
        const lowerFull = normFull.toLowerCase();
        const lowerBase = normBase.toLowerCase();
        if (!lowerFull.startsWith(lowerBase)) {
            return '';
        }
        let relative = normFull.slice(normBase.length);
        while (relative.startsWith('/')) {
            relative = relative.slice(1);
        }
        return relative;
    }

    function applyObsidianHighlightSyntax(markdown) {
        const lines = String(markdown || '').split(/\r?\n/);
        let inFence = false;
        let fenceChar = '';
        let fenceLen = 0;

        const transformed = lines.map((line) => {
            const fenceMatch = line.match(/^\s*(`{3,}|~{3,})/);
            if (fenceMatch) {
                const marker = fenceMatch[1];
                const markerChar = marker.charAt(0);
                const markerLen = marker.length;
                if (!inFence) {
                    inFence = true;
                    fenceChar = markerChar;
                    fenceLen = markerLen;
                } else if (markerChar === fenceChar && markerLen >= fenceLen) {
                    inFence = false;
                }
                return line;
            }
            if (inFence) {
                return line;
            }
            return line.replace(/==([^=\n][^=\n]*?)==/g, '<mark>$1</mark>');
        });
        return transformed.join('\n');
    }

    function transformObsidianSyntax(markdown, taskId) {
        let out = String(markdown || '');

        // Obsidian Callout 语法降级为可读 blockquote 标签，保证移动端可识别上下文。
        out = out.replace(/^>\s*\[!([A-Za-z]+)\][+-]?\s*(.*)$/gm, (_m, type, title) => {
            const t = String(type || 'NOTE').toUpperCase();
            const text = (title || '').trim();
            return `> **${t}** ${text}`;
        });

        // 处理 ![[...]] embed：图片/视频直接内嵌，其他资源转为可点击链接。
        out = out.replace(/!\[\[([^\]]+)\]\]/g, (_m, inner) => {
            const raw = String(inner || '').trim();
            const parts = raw.split('|');
            const path = (parts[0] || '').trim();
            const alias = (parts[1] || '').trim();
            if (!path) return _m;
            if (isImagePath(path)) {
                return `![](${buildAssetUrl(taskId, path)})`;
            }
            if (isVideoPath(path)) {
                return `<video controls playsinline preload="metadata" src="${buildAssetUrl(taskId, path)}"></video>`;
            }
            if (isMarkdownPath(path)) {
                const label = alias || path;
                return `[${label}](obsidian-note:${encodeURIComponent(path)})`;
            }
            const label = alias || path;
            return `[${label}](${buildAssetUrl(taskId, path)})`;
        });

        // 处理 [[...]] wikilink：优先视作同任务内笔记链接，否则当作资源链接。
        out = out.replace(/(^|[^!])\[\[([^\]]+)\]\]/g, (_m, prefix, inner) => {
            const raw = String(inner || '').trim();
            const parts = raw.split('|');
            let path = (parts[0] || '').trim();
            const alias = (parts[1] || '').trim();
            if (!path) return _m;
            const label = alias || path;
            if (!getExt(path)) {
                path = `${path}.md`;
            }
            if (isMarkdownPath(path)) {
                return `${prefix}[${label}](obsidian-note:${encodeURIComponent(path)})`;
            }
            return `${prefix}[${label}](${buildAssetUrl(taskId, path)})`;
        });

        out = applyObsidianHighlightSyntax(out);
        return out;
    }

    // 仅在移动端渲染时压缩前导缩进，不修改磁盘原文件。
    // 规则：每 4 个空格（或 1 个 tab）显示为 1 个空格；代码围栏内保持原样。
    function compressLeadingIndentForMobile(markdown) {
        const text = String(markdown || '');
        const isMobile = window.matchMedia('(max-width: 900px)').matches;
        if (!isMobile || !text) {
            return text;
        }

        const lines = text.split(/\r?\n/);
        let inFence = false;
        let fenceChar = '';
        let fenceLen = 0;

        const result = lines.map((line) => {
            const fenceMatch = line.match(/^\s*(`{3,}|~{3,})/);
            if (fenceMatch) {
                const marker = fenceMatch[1];
                const markerChar = marker.charAt(0);
                const markerLen = marker.length;
                if (!inFence) {
                    inFence = true;
                    fenceChar = markerChar;
                    fenceLen = markerLen;
                } else if (markerChar === fenceChar && markerLen >= fenceLen) {
                    inFence = false;
                }
                return line;
            }

            if (inFence) {
                return line;
            }

            const indentMatch = line.match(/^([ \t]+)(.*)$/);
            if (!indentMatch) {
                return line;
            }

            const expanded = indentMatch[1].replace(/\t/g, '    ');
            // 规则：每 4 个空格压缩为 1 个空格；不足 4 的余数保持不变。
            // 例如：4->1，8->2，6->3，3->3。
            const compactUnits = Math.floor(expanded.length / 4);
            const remainder = expanded.length % 4;
            const compactIndent = ' '.repeat(compactUnits + remainder);
            return compactIndent + indentMatch[2];
        });

        return result.join('\n');
    }

    function getMarkdownEngine(taskId) {
        if (!window.markdownit) {
            return null;
        }
        const md = window.markdownit({
            html: true,
            linkify: true,
            breaks: true,
        });
        if (window.markdownitKatex) {
            try {
                md.use(window.markdownitKatex, {
                    throwOnError: false,
                    errorColor: '#cc0000',
                });
            } catch (error) {
                console.warn('KaTeX 插件初始化失败，降级为普通文本渲染', error);
            }
        }

        const defaultImageRule = md.renderer.rules.image ||
            function(tokens, idx, options, env, self) { return self.renderToken(tokens, idx, options); };
        md.renderer.rules.image = function(tokens, idx, options, env, self) {
            const token = tokens[idx];
            const src = token.attrGet('src');
            if (src && !isAbsoluteUrl(src)) {
                token.attrSet('src', buildAssetUrl(taskId, src));
            }
            return defaultImageRule(tokens, idx, options, env, self);
        };

        const defaultLinkOpenRule = md.renderer.rules.link_open ||
            function(tokens, idx, options, env, self) { return self.renderToken(tokens, idx, options); };
        md.renderer.rules.link_open = function(tokens, idx, options, env, self) {
            const token = tokens[idx];
            const href = token.attrGet('href');
            if (href && href.startsWith('obsidian-note:')) {
                const notePath = decodeURIComponent(href.substring('obsidian-note:'.length));
                token.attrSet('href', '#');
                token.attrSet('data-note-path', notePath);
                token.attrSet('class', 'internal-note-link');
            } else if (href && !isAbsoluteUrl(href)) {
                token.attrSet('data-original-href', href);
                token.attrSet('href', buildAssetUrl(taskId, href));
            }
            return defaultLinkOpenRule(tokens, idx, options, env, self);
        };

        const defaultFenceRule = md.renderer.rules.fence ||
            function(tokens, idx, options, env, self) { return self.renderToken(tokens, idx, options); };
        md.renderer.rules.fence = function(tokens, idx, options, env, self) {
            const token = tokens[idx];
            const info = (token.info || '').trim().toLowerCase();
            if (info === 'mermaid') {
                return `<div class="mermaid">${token.content}</div>`;
            }
            return defaultFenceRule(tokens, idx, options, env, self);
        };

        return md;
    }

    async function fetchTasks() {
        const resp = await fetch(`${API_BASE}/tasks`);
        if (!resp.ok) {
            throw new Error(`获取任务列表失败: HTTP ${resp.status}`);
        }
        state.tasks = await resp.json();
        return state.tasks;
    }

    function renderTaskList() {
        const taskList = document.getElementById('taskList');
        const summary = document.getElementById('taskSummary');
        const tasks = state.tasks || [];
        const markdownTasks = tasks.filter(t => t.markdownAvailable);
        summary.textContent = `共 ${tasks.length} 个任务，可查看 Markdown ${markdownTasks.length} 个`;

        if (!tasks.length) {
            taskList.innerHTML = '<div class="empty">暂无任务，请先提交处理任务。</div>';
            return;
        }

        taskList.innerHTML = tasks.map(task => {
            const active = task.taskId === state.currentTaskId ? 'active' : '';
            const statusClass = buildStatusClass(task.status);
            const availability = task.markdownAvailable ? '可查看' : '未产出';
            return `
                <button class="task-item ${active}" data-task-id="${task.taskId}" ${task.markdownAvailable ? '' : 'disabled'}>
                    <div class="task-title">${task.title || task.taskId}</div>
                    <div class="task-meta">
                        <span>${task.taskId}</span>
                        <span class="badge ${statusClass}">${task.status || 'UNKNOWN'}</span>
                        <span>${availability}</span>
                    </div>
                    <div class="task-meta">
                        <span>创建：${formatTime(task.createdAt)}</span>
                    </div>
                </button>
            `;
        }).join('');
    }

    async function loadTaskMarkdown(taskId) {
        state.currentTaskId = taskId;
        state.editMode = false;
        state.paragraphBlocks = [];
        state.paragraphEditingIndex = -1;
        state.paragraphDraftText = '';
        state.paragraphMenuIndex = -1;
        closeCommentModal();
        renderTaskList();
        const viewerTitle = document.getElementById('viewerTitle');
        const markdownBody = document.getElementById('markdownBody');

        viewerTitle.textContent = `任务 ${taskId} 加载中...`;
        markdownBody.innerHTML = '<div class="empty">正在加载 Markdown...</div>';

        const resp = await fetch(`${API_BASE}/tasks/${encodeURIComponent(taskId)}/markdown`);
        if (!resp.ok) {
            const text = await resp.text();
            throw new Error(text || `HTTP ${resp.status}`);
        }
        const payload = await resp.json();
        state.currentMarkdownPath = payload.markdownPath || null;
        state.currentMarkdownBaseDir = payload.baseDir || null;
        state.currentMarkdownRaw = payload.markdown || '';
        state.currentTaskTitle = payload.title || taskId;
        await refreshParagraphMetaFromServer();
        syncTaskTitleFromState(state.currentTaskTitle);
        refreshViewerTitle();

        const btn = document.getElementById('toggleEditModeBtn');
        if (btn) {
            btn.textContent = '逐行编辑';
            btn.classList.remove('btn-primary');
        }
        refreshQuickActionLabels();
        renderCurrentView();
    }

    async function loadTaskMarkdownByRelativePath(taskId, relativePath) {
        const resp = await fetch(
            `${API_BASE}/tasks/${encodeURIComponent(taskId)}/markdown/by-path?path=${encodeURIComponent(relativePath)}`
        );
        if (!resp.ok) {
            const text = await resp.text();
            throw new Error(text || `HTTP ${resp.status}`);
        }
        const payload = await resp.json();
        state.currentMarkdownPath = payload.markdownPath || null;
        state.currentMarkdownBaseDir = payload.baseDir || null;
        state.currentMarkdownRaw = payload.markdown || '';
        state.paragraphBlocks = [];
        state.paragraphEditingIndex = -1;
        state.paragraphDraftText = '';
        state.paragraphMenuIndex = -1;
        closeCommentModal();
        if (!state.currentTaskTitle) {
            state.currentTaskTitle = payload.title || state.currentTaskId || '';
        }
        await refreshParagraphMetaFromServer();
        syncTaskTitleFromState(state.currentTaskTitle);
        refreshViewerTitle();
        refreshQuickActionLabels();
        renderCurrentView();
    }

    function enhanceVideoLinks(container) {
        const links = Array.from(container.querySelectorAll('a[href]'));
        links.forEach(link => {
            const href = link.getAttribute('href') || '';
            const originalHref = link.getAttribute('data-original-href') || href;
            if (!originalHref || !isVideoPath(originalHref)) return;
            if (link.dataset.previewBound === '1') return;
            link.dataset.previewBound = '1';
            const video = document.createElement('video');
            video.controls = true;
            video.playsInline = true;
            video.preload = 'metadata';
            video.src = href;
            link.insertAdjacentElement('afterend', video);
        });
    }

    function bindInternalNoteLinks(container, taskId) {
        container.querySelectorAll('a.internal-note-link[data-note-path]').forEach(link => {
            link.addEventListener('click', async (event) => {
                event.preventDefault();
                const notePath = link.getAttribute('data-note-path');
                if (!notePath) return;
                try {
                    await loadTaskMarkdownByRelativePath(taskId, notePath);
                } catch (error) {
                    showError(`打开内部笔记失败：${error.message || error}`);
                }
            });
        });
    }

    function renderMarkdownFragment(markdownText, taskId) {
        const compacted = compressLeadingIndentForMobile(markdownText);
        const transformed = transformObsidianSyntax(compacted, taskId);
        const engine = getMarkdownEngine(taskId);
        let html = '';
        if (!engine) {
            html = `<pre>${String(transformed).replace(/</g, '&lt;')}</pre>`;
        } else {
            html = engine.render(transformed);
        }
        if (window.DOMPurify) {
            html = window.DOMPurify.sanitize(html, {
                ADD_TAGS: ['video', 'source'],
                ADD_ATTR: ['controls', 'playsinline', 'preload', 'src', 'class', 'data-note-path', 'data-original-href'],
            });
        }
        return html;
    }

    function renderMarkdown(markdownText, taskId) {
        const container = document.getElementById('markdownBody');
        const html = renderMarkdownFragment(markdownText, taskId);
        container.innerHTML = html;
        bindInternalNoteLinks(container, taskId);
        enhanceVideoLinks(container);
        bindMediaLongPress(container);
        buildOutline(container);
        renderMermaid(container);
    }

    function ensureParagraphEditorState() {
        if (!state.paragraphBlocks || !state.paragraphBlocks.length) {
            state.paragraphBlocks = splitMarkdownIntoParagraphBlocks(state.currentMarkdownRaw || '');
        }
        if (!state.paragraphMeta) {
            state.paragraphMeta = { favorites: {}, comments: {} };
        }
    }

    function buildParagraphPreviewHtml(markdownText, taskId) {
        return renderMarkdownFragment(markdownText, taskId);
    }

    function normalizeParagraphComments(raw) {
        if (Array.isArray(raw)) {
            return raw.map((item) => String(item || '').trim()).filter(Boolean);
        }
        if (typeof raw === 'string') {
            const trimmed = raw.trim();
            return trimmed ? [trimmed] : [];
        }
        return [];
    }

    function getParagraphComments(index) {
        const all = state.paragraphMeta && state.paragraphMeta.comments ? state.paragraphMeta.comments : {};
        return normalizeParagraphComments(all[index]);
    }

    function setParagraphComments(index, comments) {
        const normalized = normalizeParagraphComments(comments);
        if (!state.paragraphMeta.comments) {
            state.paragraphMeta.comments = {};
        }
        if (!normalized.length) {
            delete state.paragraphMeta.comments[index];
            return;
        }
        state.paragraphMeta.comments[index] = normalized;
    }

    function normalizeCommentUnitsByLine(values) {
        const units = [];
        (values || []).forEach((value) => {
            String(value || '')
                .split(/\r?\n/)
                .map((line) => line.trim())
                .filter(Boolean)
                .forEach((line) => units.push(line));
        });
        return units;
    }

    function renderCommentModal() {
        const modal = document.getElementById('commentModal');
        const overlay = document.getElementById('commentModalOverlay');
        const body = document.getElementById('commentModalBody');
        const title = document.getElementById('commentModalTitle');
        if (!modal || !overlay || !body || !title) return;

        modal.classList.toggle('open', state.commentModalVisible);
        overlay.classList.toggle('open', state.commentModalVisible);
        if (!state.commentModalVisible) {
            return;
        }

        const pIndex = state.commentModalParagraphIndex;
        title.textContent = `第 ${pIndex + 1} 行批注（按换行拆分为独立批注）`;
        if (!state.commentModalDrafts.length) {
            body.innerHTML = '<div class="empty">暂无批注，点击“新增批注”创建</div>';
            return;
        }
        body.innerHTML = state.commentModalDrafts.map((text, idx) => `
            <section class="comment-item" data-c-idx="${idx}">
                <textarea data-c-editor="${idx}" placeholder="输入批注，换行会拆分为多条">${escapeHtml(text)}</textarea>
                <div class="comment-item-toolbar">
                    <button class="btn" data-c-action="delete" data-c-idx="${idx}" type="button">删除</button>
                </div>
            </section>
        `).join('');
    }

    function openCommentModal(index) {
        const list = getParagraphComments(index);
        state.commentModalParagraphIndex = index;
        state.commentModalDrafts = list.length ? list.slice() : [];
        state.commentModalVisible = true;
        renderCommentModal();
    }

    function closeCommentModal() {
        state.commentModalVisible = false;
        state.commentModalParagraphIndex = -1;
        state.commentModalDrafts = [];
        renderCommentModal();
    }

    function syncCommentDraftsFromDom() {
        const drafts = [];
        document.querySelectorAll('#commentModalBody [data-c-editor]').forEach((input) => {
            drafts.push(input.value || '');
        });
        state.commentModalDrafts = drafts;
    }

    function cloneParagraphMeta() {
        return {
            favorites: { ...(state.paragraphMeta.favorites || {}) },
            comments: JSON.parse(JSON.stringify(state.paragraphMeta.comments || {})),
        };
    }

    function cloneParagraphBlocks() {
        return (state.paragraphBlocks || []).map((block) => ({ ...block }));
    }

    function hideUndoToast(clearSnapshot) {
        const toast = document.getElementById('undoToast');
        if (toast) {
            toast.classList.remove('open');
        }
        if (state.undoDeleteTimeoutId) {
            clearTimeout(state.undoDeleteTimeoutId);
            state.undoDeleteTimeoutId = null;
        }
        if (clearSnapshot) {
            state.undoDeleteSnapshot = null;
        }
    }

    function showUndoToast(text, snapshot) {
        const toast = document.getElementById('undoToast');
        const label = document.getElementById('undoToastText');
        if (!toast || !label) return;
        state.undoDeleteSnapshot = snapshot;
        label.textContent = text || '已删除';
        toast.classList.add('open');
        if (state.undoDeleteTimeoutId) {
            clearTimeout(state.undoDeleteTimeoutId);
        }
        state.undoDeleteTimeoutId = setTimeout(() => {
            hideUndoToast(true);
        }, 6000);
    }

    async function undoLastDelete() {
        const snapshot = state.undoDeleteSnapshot;
        if (!snapshot) return;
        state.paragraphBlocks = snapshot.blocks.map((item) => ({ ...item }));
        state.paragraphMeta = {
            favorites: { ...(snapshot.meta.favorites || {}) },
            comments: JSON.parse(JSON.stringify(snapshot.meta.comments || {})),
        };
        try {
            await saveParagraphMeta();
            await persistParagraphBlocksAndRerender();
            hideUndoToast(true);
        } catch (error) {
            showError(`撤回删除失败：${error.message || error}`);
        }
    }

    async function deleteLineAtIndex(index, options) {
        const opts = options || {};
        if (!Number.isFinite(index) || index < 0 || index >= state.paragraphBlocks.length) {
            return;
        }
        if (opts.confirmDelete && !confirm('确认删除这一行？该操作会写回 markdown 文件。')) {
            return;
        }

        const backupBlocks = cloneParagraphBlocks();
        const backupMeta = cloneParagraphMeta();

        state.paragraphBlocks.splice(index, 1);
        state.paragraphEditingIndex = -1;
        state.paragraphDraftText = '';
        reindexParagraphMetaAfterDelete(index);

        try {
            await saveParagraphMeta();
            await persistParagraphBlocksAndRerender();
            if (opts.withUndo) {
                showUndoToast(`已删除第 ${index + 1} 行`, { blocks: backupBlocks, meta: backupMeta });
            }
        } catch (error) {
            state.paragraphBlocks = backupBlocks;
            state.paragraphMeta = backupMeta;
            showError(`删除本行失败：${error.message || error}`);
        }
    }

    function deriveFilenameFromUrl(url, fallbackBase) {
        try {
            const parsed = new URL(url, window.location.origin);
            const pathHint = parsed.searchParams.get('path');
            if (pathHint) {
                const segment = decodeURIComponent(pathHint).split('/').filter(Boolean).pop();
                if (segment) return segment;
            }
            const pathname = parsed.pathname || '';
            const tail = pathname.split('/').filter(Boolean).pop();
            if (tail && tail.includes('.')) return tail;
        } catch (_error) {
            // 忽略 URL 解析异常，回退默认文件名。
        }
        const stamp = Date.now();
        return `${fallbackBase}_${stamp}.bin`;
    }

    async function saveMediaElementToLocal(mediaEl) {
        const src = mediaEl && (mediaEl.currentSrc || mediaEl.src);
        if (!src) {
            alert('未找到可保存的媒体链接');
            return;
        }
        const isVideo = mediaEl.tagName && mediaEl.tagName.toLowerCase() === 'video';
        const fallbackBase = isVideo ? 'video_clip' : 'image_asset';
        const filename = deriveFilenameFromUrl(src, fallbackBase);

        const resp = await fetch(src);
        if (!resp.ok) {
            throw new Error(`HTTP ${resp.status}`);
        }
        const blob = await resp.blob();
        const blobUrl = URL.createObjectURL(blob);
        try {
            const a = document.createElement('a');
            a.href = blobUrl;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            a.remove();
        } finally {
            URL.revokeObjectURL(blobUrl);
        }
    }

    function bindMediaLongPress(container) {
        if (!container) return;
        const mediaNodes = container.querySelectorAll('img, video');
        mediaNodes.forEach((node) => {
            if (node.dataset.saveBound === '1') return;
            node.dataset.saveBound = '1';

            const clearTimer = () => {
                if (state.mediaPressTimer) {
                    clearTimeout(state.mediaPressTimer);
                    state.mediaPressTimer = null;
                }
            };

            node.addEventListener('touchstart', () => {
                clearTimer();
                state.mediaPressTimer = setTimeout(async () => {
                    state.mediaPressTimer = null;
                    const ok = confirm('是否保存该媒体到本地？');
                    if (!ok) return;
                    try {
                        await saveMediaElementToLocal(node);
                    } catch (error) {
                        alert(`保存失败：${error.message || error}`);
                    }
                }, 2000);
            }, { passive: true });
            node.addEventListener('touchmove', clearTimer, { passive: true });
            node.addEventListener('touchend', clearTimer, { passive: true });
            node.addEventListener('touchcancel', clearTimer, { passive: true });
            node.addEventListener('contextmenu', async (event) => {
                event.preventDefault();
                const ok = confirm('是否保存该媒体到本地？');
                if (!ok) return;
                try {
                    await saveMediaElementToLocal(node);
                } catch (error) {
                    alert(`保存失败：${error.message || error}`);
                }
            });
        });
    }

    function touchDistance(t1, t2) {
        const dx = t1.clientX - t2.clientX;
        const dy = t1.clientY - t2.clientY;
        return Math.sqrt(dx * dx + dy * dy);
    }

    function buildParagraphMenuHtml(index, favorite, editing, commentCount) {
        const open = state.paragraphMenuIndex === index;
        const actions = [];
        if (editing) {
            actions.push({ action: 'save-edit', label: '保存本行' });
            actions.push({ action: 'cancel-edit', label: '取消编辑' });
        } else {
            actions.push({ action: 'edit', label: '编辑本行' });
        }
        actions.push({ action: 'copy', label: '复制本行' });
        actions.push({ action: 'favorite', label: favorite ? '取消收藏' : '收藏本行', cls: favorite ? 'favorite' : '' });
        actions.push({ action: 'comment', label: '批注本行' });
        actions.push({ action: 'style-italic', label: '变斜体' });
        actions.push({ action: 'style-underline', label: '加下划线' });
        actions.push({ action: 'style-highlight', label: '加高亮' });
        actions.push({ action: 'delete', label: '删除本行' });

        const items = actions.map((item) => {
            const cls = item.cls ? ` ${item.cls}` : '';
            return `<button class="paragraph-menu-item${cls}" data-p-action="${item.action}" data-p-index="${index}">${item.label}</button>`;
        }).join('');

        const bubbleHtml = commentCount > 0
            ? `<button class="paragraph-comment-badge" data-p-action="open-comments" data-p-index="${index}" title="查看批注">${commentCount}</button>`
            : '';

        return `
            <div class="paragraph-menu-row">
                ${bubbleHtml}
                <div class="paragraph-menu-wrap">
                    <button class="paragraph-plus-btn" data-p-action="toggle-menu" data-p-index="${index}">+</button>
                    <div class="paragraph-menu ${open ? 'open' : ''}">
                        ${items}
                    </div>
                </div>
            </div>
        `;
    }

    function renderParagraphEditor(taskId) {
        ensureParagraphEditorState();
        const container = document.getElementById('markdownBody');
        if (!state.paragraphBlocks.length) {
            container.innerHTML = '<div class="empty">当前文档没有可编辑内容</div>';
            buildOutline(container);
            teardownScrollSpy();
            return;
        }

        const cards = state.paragraphBlocks.map((block, index) => {
            const favorite = !!state.paragraphMeta.favorites[index];
            const comments = getParagraphComments(index);
            const commentCount = comments.length;
            const latestComment = commentCount ? comments[commentCount - 1] : '';
            const editing = state.paragraphEditingIndex === index;
            const previewHtml = block.text
                ? buildParagraphPreviewHtml(block.text, taskId)
                : '<span style="color:#94a3b8;">（空行）</span>';
            const noteHtml = latestComment
                ? `<div class="paragraph-note">最近批注：${escapeHtml(latestComment)}${commentCount > 1 ? `（共 ${commentCount} 条）` : ''}</div>`
                : '';
            const menuHtml = buildParagraphMenuHtml(index, favorite, editing, commentCount);

            if (editing) {
                return `
                    <section class="paragraph-card" data-p-index="${index}">
                        ${noteHtml}
                        <textarea class="paragraph-textarea" data-p-editor="${index}">${escapeHtml(state.paragraphDraftText)}</textarea>
                        ${menuHtml}
                    </section>
                `;
            }
            return `
                <section class="paragraph-card" data-p-index="${index}">
                    ${noteHtml}
                    <div class="paragraph-preview">${previewHtml}</div>
                    ${menuHtml}
                </section>
            `;
        });

        container.innerHTML = `<div class="paragraph-list">${cards.join('')}</div>`;
        bindInternalNoteLinks(container, taskId);
        enhanceVideoLinks(container);
        bindMediaLongPress(container);
        buildOutline(container);
        renderMermaid(container);
    }

    function setEditMode(enabled) {
        state.editMode = !!enabled;
        const btn = document.getElementById('toggleEditModeBtn');
        if (btn) {
            btn.textContent = state.editMode ? '退出编辑' : '逐行编辑';
            btn.classList.toggle('btn-primary', state.editMode);
        }
        if (state.editMode) {
            state.paragraphBlocks = splitMarkdownIntoParagraphBlocks(state.currentMarkdownRaw || '');
            state.paragraphMenuIndex = -1;
        } else {
            state.paragraphEditingIndex = -1;
            state.paragraphDraftText = '';
            state.paragraphMenuIndex = -1;
            closeCommentModal();
        }
        refreshQuickActionLabels();
        renderCurrentView();
    }

    function renderCurrentView() {
        if (!state.currentTaskId) return;
        if (state.editMode) {
            renderParagraphEditor(state.currentTaskId);
        } else {
            renderMarkdown(state.currentMarkdownRaw || '', state.currentTaskId);
        }
    }

    async function persistParagraphBlocksAndRerender() {
        const markdown = joinParagraphBlocks(state.paragraphBlocks);
        const result = await saveMarkdownToServer(markdown);
        state.currentMarkdownRaw = markdown;
        if (result && result.markdownPath) {
            state.currentMarkdownPath = result.markdownPath;
        }
        if (result && result.baseDir) {
            state.currentMarkdownBaseDir = result.baseDir;
        }
        refreshViewerTitle();
        renderCurrentView();
    }

    function reindexParagraphMetaAfterDelete(deletedIndex) {
        const nextFavorites = {};
        const nextComments = {};
        Object.keys(state.paragraphMeta.favorites || {}).forEach((k) => {
            const idx = Number(k);
            if (!Number.isFinite(idx) || idx === deletedIndex) return;
            const newIdx = idx > deletedIndex ? idx - 1 : idx;
            nextFavorites[newIdx] = state.paragraphMeta.favorites[k];
        });
        Object.keys(state.paragraphMeta.comments || {}).forEach((k) => {
            const idx = Number(k);
            if (!Number.isFinite(idx) || idx === deletedIndex) return;
            const newIdx = idx > deletedIndex ? idx - 1 : idx;
            nextComments[newIdx] = state.paragraphMeta.comments[k];
        });
        state.paragraphMeta = { favorites: nextFavorites, comments: nextComments };
    }

    function toggleWrappedTag(rawText, tagName) {
        const text = String(rawText || '');
        const leading = (text.match(/^\s*/) || [''])[0];
        const trailing = (text.match(/\s*$/) || [''])[0];
        const start = leading.length;
        const end = text.length - trailing.length;
        const core = text.substring(start, end);
        if (!core) {
            return text;
        }

        const openTag = `<${tagName}>`;
        const closeTag = `</${tagName}>`;
        const lower = core.toLowerCase();
        if (lower.startsWith(openTag) && lower.endsWith(closeTag) && core.length > openTag.length + closeTag.length) {
            const unwrapped = core.substring(openTag.length, core.length - closeTag.length);
            return `${leading}${unwrapped}${trailing}`;
        }
        return `${leading}${openTag}${core}${closeTag}${trailing}`;
    }

    function applyParagraphStyleText(rawText, styleAction) {
        if (styleAction === 'style-italic') {
            return toggleWrappedTag(rawText, 'em');
        }
        if (styleAction === 'style-underline') {
            return toggleWrappedTag(rawText, 'u');
        }
        if (styleAction === 'style-highlight') {
            return toggleWrappedTag(rawText, 'mark');
        }
        return String(rawText || '');
    }

    async function applyParagraphStyle(index, styleAction) {
        const block = state.paragraphBlocks[index];
        if (!block) {
            return;
        }
        let sourceText = String(block.text || '');
        if (state.paragraphEditingIndex === index) {
            const editor = document.querySelector(`[data-p-editor="${index}"]`);
            if (editor) {
                sourceText = editor.value;
            }
        }
        const nextText = applyParagraphStyleText(sourceText, styleAction);
        if (nextText === sourceText) {
            return;
        }

        const oldText = block.text;
        block.text = nextText;
        if (state.paragraphEditingIndex === index) {
            state.paragraphDraftText = nextText;
        }

        try {
            await persistParagraphBlocksAndRerender();
        } catch (error) {
            block.text = oldText;
            if (state.paragraphEditingIndex === index) {
                state.paragraphDraftText = oldText;
            }
            throw error;
        }
    }

    async function copyParagraphText(index) {
        const block = state.paragraphBlocks[index];
        if (!block) return;
        const text = String(block.text || '');
        try {
            if (navigator.clipboard && navigator.clipboard.writeText) {
                await navigator.clipboard.writeText(text);
            } else {
                const ta = document.createElement('textarea');
                ta.value = text;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                ta.remove();
            }
            alert('本行已复制');
        } catch (error) {
            alert(`复制失败：${error.message || error}`);
        }
    }

    function showError(message) {
        const container = document.getElementById('markdownBody');
        container.innerHTML = `<div class="error">${message}</div>`;
        teardownScrollSpy();
        const outlineList = document.getElementById('outlineList');
        if (outlineList) {
            outlineList.innerHTML = '<div class="empty">暂无可跳转标题</div>';
        }
    }

    async function saveParagraphMeta(update) {
        const hasTaskTitle = !!(update && Object.prototype.hasOwnProperty.call(update, 'taskTitle'));
        const payload = {
            favorites: update && update.favorites ? update.favorites : (state.paragraphMeta.favorites || {}),
            comments: update && update.comments ? update.comments : (state.paragraphMeta.comments || {}),
        };
        if (hasTaskTitle) {
            payload.taskTitle = update.taskTitle;
        }

        paragraphMetaSaveQueue = paragraphMetaSaveQueue
            .catch(() => null)
            .then(async () => {
                const saved = await retryAsync(() => saveTaskMetaToServer(payload), 2);
                state.paragraphMeta = {
                    favorites: saved && saved.favorites ? saved.favorites : {},
                    comments: saved && saved.comments ? saved.comments : {},
                };
                if (saved && typeof saved.taskTitle === 'string') {
                    const title = saved.taskTitle.trim();
                    state.currentTaskTitle = title;
                    if (title) {
                        syncTaskTitleFromState(title);
                    }
                }
                return saved;
            });
        return paragraphMetaSaveQueue;
    }

    function getDownloadFilename(resp, fallback) {
        const disposition = resp.headers.get('content-disposition') || '';
        if (!disposition) {
            return fallback;
        }
        const utf8Match = disposition.match(/filename\*=UTF-8''([^;]+)/i);
        if (utf8Match && utf8Match[1]) {
            try {
                return decodeURIComponent(utf8Match[1]);
            } catch (_error) {
                return utf8Match[1];
            }
        }
        const plainMatch = disposition.match(/filename="?([^";]+)"?/i);
        if (plainMatch && plainMatch[1]) {
            return plainMatch[1];
        }
        return fallback;
    }

    async function exportCurrentTaskZip() {
        if (!state.currentTaskId) {
            alert('请先选择任务');
            return;
        }
        const resp = await fetch(`${API_BASE}/tasks/${encodeURIComponent(state.currentTaskId)}/export`);
        if (!resp.ok) {
            const text = await resp.text();
            throw new Error(text || `HTTP ${resp.status}`);
        }
        const blob = await resp.blob();
        const fallback = `${String(state.currentTaskId).replace(/[:\\/]/g, '_')}_bundle.zip`;
        const filename = getDownloadFilename(resp, fallback);
        const url = URL.createObjectURL(blob);
        try {
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            a.remove();
        } finally {
            URL.revokeObjectURL(url);
        }
    }

    async function renameCurrentTask() {
        if (!state.currentTaskId) {
            alert('请先选择任务');
            return;
        }
        const fallbackTitle = state.currentTaskTitle || state.currentTaskId;
        const input = prompt('请输入新的任务展示名称（留空恢复默认）', fallbackTitle);
        if (input === null) {
            return;
        }
        const nextTitle = String(input).trim();
        await saveParagraphMeta({ taskTitle: nextTitle });
        await fetchTasks();
        renderTaskList();

        if (nextTitle) {
            state.currentTaskTitle = nextTitle;
            syncTaskTitleFromState(nextTitle);
        } else {
            const current = (state.tasks || []).find((task) => task.taskId === state.currentTaskId);
            state.currentTaskTitle = current ? (current.title || state.currentTaskId) : state.currentTaskId;
        }
        refreshViewerTitle();
    }

    async function renderMermaid(container) {
        if (!window.mermaid) return;
        try {
            mermaid.initialize({ startOnLoad: false, securityLevel: 'loose' });
            const nodes = container.querySelectorAll('.mermaid');
            if (!nodes.length) return;
            await mermaid.run({ nodes });
        } catch (error) {
            console.warn('Mermaid 渲染失败', error);
        }
    }

    function bindEvents() {
        document.getElementById('refreshBtn').addEventListener('click', async () => {
            try {
                await fetchTasks();
                renderTaskList();
            } catch (error) {
                showError(`刷新任务失败：${error.message || error}`);
            }
        });

        document.getElementById('reloadCurrentBtn').addEventListener('click', async () => {
            if (!state.currentTaskId) return;
            try {
                await loadTaskMarkdown(state.currentTaskId);
            } catch (error) {
                showError(`重载失败：${error.message || error}`);
            }
        });

        const toggleEditBtn = document.getElementById('toggleEditModeBtn');
        if (toggleEditBtn) {
            toggleEditBtn.addEventListener('click', () => {
                if (!state.currentTaskId) {
                    alert('请先选择任务');
                    return;
                }
                setEditMode(!state.editMode);
            });
        }

        document.getElementById('renameTaskBtn').addEventListener('click', async () => {
            try {
                await renameCurrentTask();
            } catch (error) {
                alert(`重命名失败：${error.message || error}`);
            }
        });

        document.getElementById('exportTaskBtn').addEventListener('click', async () => {
            try {
                await exportCurrentTaskZip();
            } catch (error) {
                alert(`导出失败：${error.message || error}`);
            }
        });

        document.getElementById('taskList').addEventListener('click', async (event) => {
            const item = event.target.closest('[data-task-id]');
            if (!item) return;
            const taskId = item.getAttribute('data-task-id');
            if (!taskId) return;
            try {
                await loadTaskMarkdown(taskId);
            } catch (error) {
                showError(`加载任务失败：${error.message || error}`);
            }
        });

        document.getElementById('quickFabBtn').addEventListener('click', () => {
            state.quickFabOpen = !state.quickFabOpen;
            applyQuickFabMenuVisibility();
        });

        document.getElementById('quickActionOutline').addEventListener('click', () => {
            state.outlineVisible = !state.outlineVisible;
            applyOutlineVisibility();
            closeQuickFabMenu();
        });

        document.getElementById('quickActionEdit').addEventListener('click', () => {
            if (!state.currentTaskId) {
                alert('请先选择任务');
                closeQuickFabMenu();
                return;
            }
            setEditMode(!state.editMode);
            closeQuickFabMenu();
        });

        document.getElementById('quickActionExport').addEventListener('click', async () => {
            try {
                await exportCurrentTaskZip();
            } catch (error) {
                alert(`导出失败：${error.message || error}`);
            } finally {
                closeQuickFabMenu();
            }
        });

        document.getElementById('outlineOverlay').addEventListener('click', () => {
            if (!state.outlineVisible) return;
            state.outlineVisible = false;
            applyOutlineVisibility();
        });

        document.getElementById('outlineList').addEventListener('click', (event) => {
            const link = event.target.closest('[data-target-id]');
            if (!link) return;
            const targetId = link.getAttribute('data-target-id');
            if (!targetId) return;
            const heading = document.getElementById(targetId);
            if (!heading) return;
            heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
            setActiveOutline(targetId);
            state.outlineVisible = false;
            applyOutlineVisibility();
        });

        document.addEventListener('click', (event) => {
            if (!state.quickFabOpen) return;
            if (event.target.closest('#quickFabWrap')) return;
            closeQuickFabMenu();
        });

        document.getElementById('commentModalCloseBtn').addEventListener('click', () => {
            closeCommentModal();
        });

        document.getElementById('commentModalOverlay').addEventListener('click', () => {
            closeCommentModal();
        });

        document.getElementById('commentModalBody').addEventListener('input', (event) => {
            if (!event.target.closest('[data-c-editor]')) return;
            syncCommentDraftsFromDom();
        });

        document.getElementById('commentModalBody').addEventListener('click', (event) => {
            const delBtn = event.target.closest('[data-c-action="delete"]');
            if (!delBtn) return;
            const idx = Number(delBtn.getAttribute('data-c-idx'));
            if (!Number.isFinite(idx) || idx < 0) return;
            syncCommentDraftsFromDom();
            state.commentModalDrafts.splice(idx, 1);
            renderCommentModal();
        });

        document.getElementById('commentModalAddBtn').addEventListener('click', () => {
            syncCommentDraftsFromDom();
            state.commentModalDrafts.push('');
            renderCommentModal();
        });

        document.getElementById('commentModalSaveBtn').addEventListener('click', async () => {
            if (state.commentModalParagraphIndex < 0) {
                closeCommentModal();
                return;
            }
            syncCommentDraftsFromDom();
            const normalized = normalizeCommentUnitsByLine(state.commentModalDrafts);
            setParagraphComments(state.commentModalParagraphIndex, normalized);
            try {
                await saveParagraphMeta();
                closeCommentModal();
                if (state.editMode && state.currentTaskId) {
                    renderParagraphEditor(state.currentTaskId);
                }
            } catch (error) {
                showError(`批注保存失败：${error.message || error}`);
            }
        });

        document.getElementById('undoToastBtn').addEventListener('click', async () => {
            await undoLastDelete();
        });

        const markdownBody = document.getElementById('markdownBody');

        markdownBody.addEventListener('touchstart', (event) => {
            if (!event.touches || event.touches.length !== 2) return;
            state.pinchStartDistance = touchDistance(event.touches[0], event.touches[1]);
            state.pinchTriggered = false;
        }, { passive: true });

        markdownBody.addEventListener('touchmove', (event) => {
            if (!event.touches || event.touches.length !== 2 || state.pinchStartDistance <= 0 || state.pinchTriggered) return;
            const currentDistance = touchDistance(event.touches[0], event.touches[1]);
            if (currentDistance <= state.pinchStartDistance * 0.78) {
                state.pinchTriggered = true;
                state.outlineVisible = true;
                applyOutlineVisibility();
                closeQuickFabMenu();
            }
        }, { passive: true });

        markdownBody.addEventListener('touchend', (event) => {
            if (event.touches && event.touches.length >= 2) return;
            state.pinchStartDistance = 0;
            state.pinchTriggered = false;
        }, { passive: true });

        markdownBody.addEventListener('dblclick', async (event) => {
            if (!state.editMode) return;
            if (event.target.closest('button, textarea, .paragraph-menu-wrap, img, video')) return;
            const card = event.target.closest('.paragraph-card[data-p-index]');
            if (!card) return;
            const index = Number(card.getAttribute('data-p-index'));
            if (!Number.isFinite(index) || index < 0) return;
            await copyParagraphText(index);
        });

        markdownBody.addEventListener('touchstart', (event) => {
            if (!state.editMode) return;
            if (!event.touches || event.touches.length !== 1) return;
            if (event.target.closest('button, textarea, .paragraph-menu-wrap, img, video')) return;
            const card = event.target.closest('.paragraph-card[data-p-index]');
            if (!card) return;
            const index = Number(card.getAttribute('data-p-index'));
            if (!Number.isFinite(index) || index < 0) return;
            const touch = event.touches && event.touches[0];
            if (!touch) return;

            if (state.touchGesture && state.touchGesture.longPressTimer) {
                clearTimeout(state.touchGesture.longPressTimer);
            }
            const gesture = {
                index,
                startX: touch.clientX,
                startY: touch.clientY,
                lastX: touch.clientX,
                lastY: touch.clientY,
                moved: false,
                longPressTriggered: false,
                longPressTimer: null,
            };
            gesture.longPressTimer = setTimeout(() => {
                gesture.longPressTriggered = true;
                state.paragraphEditingIndex = index;
                state.paragraphDraftText = (state.paragraphBlocks[index] && state.paragraphBlocks[index].text) || '';
                renderParagraphEditor(state.currentTaskId);
            }, 2000);
            state.touchGesture = gesture;
        }, { passive: true });

        markdownBody.addEventListener('touchmove', (event) => {
            const gesture = state.touchGesture;
            if (!gesture) return;
            const touch = event.touches && event.touches[0];
            if (!touch) return;
            gesture.lastX = touch.clientX;
            gesture.lastY = touch.clientY;
            const dx = gesture.lastX - gesture.startX;
            const dy = gesture.lastY - gesture.startY;
            if (Math.abs(dx) > 10 || Math.abs(dy) > 10) {
                gesture.moved = true;
                if (gesture.longPressTimer) {
                    clearTimeout(gesture.longPressTimer);
                    gesture.longPressTimer = null;
                }
            }
        }, { passive: true });

        markdownBody.addEventListener('touchcancel', () => {
            const gesture = state.touchGesture;
            if (!gesture) return;
            if (gesture.longPressTimer) {
                clearTimeout(gesture.longPressTimer);
            }
            state.touchGesture = null;
        }, { passive: true });

        markdownBody.addEventListener('touchend', async () => {
            const gesture = state.touchGesture;
            if (!gesture) return;
            if (gesture.longPressTimer) {
                clearTimeout(gesture.longPressTimer);
                gesture.longPressTimer = null;
            }
            state.touchGesture = null;
            if (gesture.longPressTriggered) {
                return;
            }

            const dx = gesture.lastX - gesture.startX;
            const dy = gesture.lastY - gesture.startY;
            const absX = Math.abs(dx);
            const absY = Math.abs(dy);

            if (absX >= 72 && absX > absY * 1.2) {
                if (dx > 0) {
                    openCommentModal(gesture.index);
                } else {
                    await deleteLineAtIndex(gesture.index, { confirmDelete: false, withUndo: true });
                }
                return;
            }

            if (absX < 12 && absY < 12) {
                const now = Date.now();
                if (state.lastTapIndex === gesture.index && now - state.lastTapAt <= 330) {
                    await copyParagraphText(gesture.index);
                    state.lastTapAt = 0;
                    state.lastTapIndex = -1;
                } else {
                    state.lastTapAt = now;
                    state.lastTapIndex = gesture.index;
                }
            }
        }, { passive: true });

        document.addEventListener('click', (event) => {
            if (!state.editMode || state.paragraphMenuIndex < 0 || !state.currentTaskId) {
                return;
            }
            if (event.target.closest('.paragraph-menu-wrap')) {
                return;
            }
            state.paragraphMenuIndex = -1;
            renderParagraphEditor(state.currentTaskId);
        });

        document.getElementById('markdownBody').addEventListener('click', async (event) => {
            const actionBtn = event.target.closest('[data-p-action]');
            if (!actionBtn || !state.editMode) return;

            const action = actionBtn.getAttribute('data-p-action');
            const index = Number(actionBtn.getAttribute('data-p-index'));
            if (!Number.isFinite(index) || index < 0) return;

            if (action === 'toggle-menu') {
                state.paragraphMenuIndex = state.paragraphMenuIndex === index ? -1 : index;
                renderParagraphEditor(state.currentTaskId);
                return;
            }

            if (action === 'open-comments') {
                openCommentModal(index);
                return;
            }

            state.paragraphMenuIndex = -1;

            if (action === 'edit') {
                const block = state.paragraphBlocks[index];
                if (!block) return;
                state.paragraphEditingIndex = index;
                state.paragraphDraftText = block.text || '';
                renderParagraphEditor(state.currentTaskId);
                return;
            }

            if (action === 'cancel-edit') {
                state.paragraphEditingIndex = -1;
                state.paragraphDraftText = '';
                renderParagraphEditor(state.currentTaskId);
                return;
            }

            if (action === 'save-edit') {
                const editor = document.querySelector(`[data-p-editor="${index}"]`);
                const nextText = editor ? editor.value : state.paragraphDraftText;
                const oldText = state.paragraphBlocks[index].text;
                state.paragraphBlocks[index].text = nextText;
                state.paragraphEditingIndex = -1;
                state.paragraphDraftText = '';
                try {
                    await persistParagraphBlocksAndRerender();
                } catch (error) {
                    state.paragraphBlocks[index].text = oldText;
                    showError(`保存本行失败：${error.message || error}`);
                }
                return;
            }

            if (action === 'delete') {
                await deleteLineAtIndex(index, { confirmDelete: true, withUndo: false });
                return;
            }

            if (action === 'copy') {
                await copyParagraphText(index);
                renderParagraphEditor(state.currentTaskId);
                return;
            }

            if (action === 'favorite') {
                const current = !!state.paragraphMeta.favorites[index];
                if (current) {
                    delete state.paragraphMeta.favorites[index];
                } else {
                    state.paragraphMeta.favorites[index] = true;
                }
                try {
                    await saveParagraphMeta();
                } catch (error) {
                    showError(`收藏状态保存失败：${error.message || error}`);
                    return;
                }
                renderParagraphEditor(state.currentTaskId);
                return;
            }

            if (action === 'comment') {
                openCommentModal(index);
                return;
            }

            if (action === 'style-italic' || action === 'style-underline' || action === 'style-highlight') {
                try {
                    await applyParagraphStyle(index, action);
                } catch (error) {
                    showError(`行样式应用失败：${error.message || error}`);
                }
                return;
            }
        });

        document.getElementById('markdownBody').addEventListener('input', (event) => {
            const editor = event.target.closest('[data-p-editor]');
            if (!editor || !state.editMode) return;
            const idx = Number(editor.getAttribute('data-p-editor'));
            if (idx === state.paragraphEditingIndex) {
                state.paragraphDraftText = editor.value;
            }
        });
    }

    async function bootstrap() {
        bindEvents();
        state.quickFabOpen = false;
        applyQuickFabMenuVisibility();
        applyOutlineVisibility();
        refreshQuickActionLabels();
        renderCommentModal();
        try {
            await fetchTasks();
            renderTaskList();
            const query = new URLSearchParams(window.location.search);
            const preferredTaskId = query.get('taskId');
            let toOpen = null;
            if (preferredTaskId) {
                toOpen = state.tasks.find(t => t.taskId === preferredTaskId && t.markdownAvailable);
            }
            if (!toOpen) {
                toOpen = state.tasks.find(t => t.markdownAvailable);
            }
            if (toOpen) {
                await loadTaskMarkdown(toOpen.taskId);
            }
        } catch (error) {
            showError(`初始化失败：${error.message || error}`);
        }
    }

    function buildOutline(container) {
        const outlineList = document.getElementById('outlineList');
        if (!outlineList) return;

        const headings = Array.from(container.querySelectorAll('h1, h2, h3, h4'));
        state.outlineHeadings = headings;
        if (!headings.length) {
            outlineList.innerHTML = '<div class="empty">暂无可跳转标题</div>';
            state.activeOutlineId = '';
            teardownScrollSpy();
            return;
        }

        const usedIds = new Set();
        const items = headings.map((heading, index) => {
            let id = heading.id ? String(heading.id).trim() : '';
            if (!id || usedIds.has(id)) {
                id = `md-heading-${index + 1}`;
            }
            while (usedIds.has(id)) {
                id = `${id}-x`;
            }
            usedIds.add(id);
            heading.id = id;
            const level = Number(heading.tagName.substring(1)) || 1;
            const text = (heading.textContent || '').trim() || `标题 ${index + 1}`;
            return `<a class="outline-item outline-level-${level}" href="javascript:void(0)" data-target-id="${id}">${escapeHtml(text)}</a>`;
        });

        outlineList.innerHTML = items.join('');
        installScrollSpy(headings);
    }

    function setActiveOutline(targetId) {
        if (!targetId) return;
        state.activeOutlineId = targetId;
        document.querySelectorAll('#outlineList .outline-item').forEach((item) => {
            const isActive = item.getAttribute('data-target-id') === targetId;
            item.classList.toggle('active', isActive);
        });
    }

    function teardownScrollSpy() {
        if (state.scrollSpyHandler) {
            window.removeEventListener('scroll', state.scrollSpyHandler);
            state.scrollSpyHandler = null;
        }
    }

    function installScrollSpy(headings) {
        teardownScrollSpy();
        if (!headings || !headings.length) return;

        const handler = () => {
            const anchorY = 120;
            let current = headings[0];
            for (let i = 0; i < headings.length; i += 1) {
                const top = headings[i].getBoundingClientRect().top;
                if (top <= anchorY) {
                    current = headings[i];
                } else {
                    break;
                }
            }
            if (current && current.id) {
                setActiveOutline(current.id);
            }
        };

        state.scrollSpyHandler = handler;
        window.addEventListener('scroll', handler, { passive: true });
        handler();
    }

    function applyQuickFabMenuVisibility() {
        const menu = document.getElementById('quickFabMenu');
        const btn = document.getElementById('quickFabBtn');
        if (!menu || !btn) return;
        menu.classList.toggle('open', state.quickFabOpen);
        btn.classList.toggle('active', state.quickFabOpen);
    }

    function closeQuickFabMenu() {
        if (!state.quickFabOpen) return;
        state.quickFabOpen = false;
        applyQuickFabMenuVisibility();
    }

    function refreshQuickActionLabels() {
        const outlineBtn = document.getElementById('quickActionOutline');
        if (outlineBtn) {
            outlineBtn.textContent = state.outlineVisible ? '收起大纲' : '打开大纲';
        }
        const editBtn = document.getElementById('quickActionEdit');
        if (editBtn) {
            editBtn.textContent = state.editMode ? '退出逐行编辑' : '开启逐行编辑';
        }
    }

    function applyOutlineVisibility() {
        const panel = document.getElementById('outlinePanel');
        const overlay = document.getElementById('outlineOverlay');
        if (!panel || !overlay) return;
        panel.classList.toggle('open', state.outlineVisible);
        overlay.classList.toggle('open', state.outlineVisible);
        refreshQuickActionLabels();
    }

    document.addEventListener('DOMContentLoaded', bootstrap);
</script>
</body>
</html>

