  "SUB292": {
    "start_sec": 582.0,
    "end_sec": 584.0,
    "text": "可以把各种第三方的生态接入进来"
  },
  "SUB293": {
    "start_sec": 584.0,
    "end_sec": 586.0,
    "text": "比如这里的GiuGscuse"
  },
  "SUB294": {
    "start_sec": 586.0,
    "end_sec": 588.0,
    "text": "可以把谷歌邮箱日历"
  },
  "SUB295": {
    "start_sec": 588.0,
    "end_sec": 590.0,
    "text": "文档等功能都接入CuddledBout"
