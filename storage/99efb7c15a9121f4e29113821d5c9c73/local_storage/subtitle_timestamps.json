  "SUB280": {
    "start_sec": 558.0,
    "end_sec": 560.0,
    "text": "模型选择minimax"
  },
  "SUB281": {
    "start_sec": 560.0,
    "end_sec": 562.0,
    "text": "然后我们把刚才创建的minimax API Key"
  },
  "SUB282": {
    "start_sec": 562.0,
    "end_sec": 564.0,
    "text": "填写进来"
  },
  "SUB283": {
    "start_sec": 564.0,
    "end_sec": 566.0,
    "text": "一路回车就配置完成"
  },
  "SUB284": {
    "start_sec": 566.0,
    "end_sec": 568.0,
    "text": "来到ChatGLM的控制台"
  },
  "SUB285": {
    "start_sec": 568.0,
    "end_sec": 570.0,
    "text": "输入minimax列出models"
