{
  "SUB001": {
    "start_sec": 0.0,
    "end_sec": 2.0,
    "text": "Clothbolt一夜爆火"
  },
  "SUB002": {
    "start_sec": 2.0,
    "end_sec": 4.0,
    "text": "这是一个运行在本地电脑的开源AI助理"
  },
  "SUB003": {
    "start_sec": 4.0,
    "end_sec": 6.0,
    "text": "短短几天内"
  },
  "SUB004": {
    "start_sec": 6.0,
    "end_sec": 8.0,
    "text": "Github Star数量直线拉升"
  },
  "SUB005": {
    "start_sec": 8.0,
    "end_sec": 10.0,
    "text": "已经超过了12万"
  },
  "SUB006": {
    "start_sec": 10.0,
    "end_sec": 12.0,
    "text": "本期视频我们带来一个"
  },
  "SUB007": {
    "start_sec": 12.0,
    "end_sec": 14.0,
    "text": "Clothbolt的全面攻略"
  },
  "SUB008": {
    "start_sec": 14.0,
    "end_sec": 16.0,
    "text": "看看Clothbolt"
  },
  "SUB009": {
    "start_sec": 16.0,
    "end_sec": 18.0,
    "text": "比起其他的AI巨头有什么特色"
  },
  "SUB010": {
    "start_sec": 18.0,
    "end_sec": 20.0,
    "text": "我准备了十几个案例的玩法大全"
  },
  "SUB011": {
    "start_sec": 20.0,
    "end_sec": 22.0,
    "text": "还会介绍一个接入飞书"
  },
  "SUB012": {
    "start_sec": 22.0,
    "end_sec": 24.0,
    "text": "加国产模型的方案"
  },
  "SUB013": {
    "start_sec": 24.0,
    "end_sec": 26.0,
    "text": "让Clothbolt在国内网络也能顺畅使用"
  },
  "SUB014": {
    "start_sec": 26.0,
    "end_sec": 28.0,
    "text": "视频开始之前先插入一个小插曲"
  },
  "SUB015": {
    "start_sec": 28.0,
    "end_sec": 30.0,
    "text": "由于Clothbolt收到安斯尔培克"
  },
  "SUB016": {
    "start_sec": 30.0,
    "end_sec": 32.0,
    "text": "法务团队的压力"
  },
  "SUB017": {
    "start_sec": 32.0,
    "end_sec": 34.0,
    "text": "Clothbolt先是改名成了"
  },
  "SUB018": {
    "start_sec": 34.0,
    "end_sec": 36.0,
    "text": "Maltbolt现在又改名成了OpenCloth"
  },
  "SUB019": {
    "start_sec": 36.0,
    "end_sec": 38.0,
    "text": "爬巴瞎做视频的速度"
  },
  "SUB020": {
    "start_sec": 38.0,
    "end_sec": 40.0,
    "text": "还赶不上它改名的速度"
  },
  "SUB021": {
    "start_sec": 40.0,
    "end_sec": 42.0,
    "text": "所以本期视频"
  },
  "SUB022": {
    "start_sec": 42.0,
    "end_sec": 44.0,
    "text": "我们还是统一叫它最开始的名字"
  },
  "SUB023": {
    "start_sec": 44.0,
    "end_sec": 46.0,
    "text": "Clothbolt"
  },
  "SUB024": {
    "start_sec": 46.0,
    "end_sec": 48.0,
    "text": "Clothbolt功能跟Clothcode和Opencode"
  },
  "SUB025": {
    "start_sec": 48.0,
    "end_sec": 50.0,
    "text": "都有点像"
  },
  "SUB026": {
    "start_sec": 50.0,
    "end_sec": 52.0,
    "text": "都可以处理文件"
  },
  "SUB027": {
    "start_sec": 52.0,
    "end_sec": 54.0,
    "text": "编码"
  },
  "SUB028": {
    "start_sec": 54.0,
    "end_sec": 56.0,
    "text": "调用Skills"
  },
  "SUB029": {
    "start_sec": 56.0,
    "end_sec": 58.0,
    "text": "MCP等等"
  },
  "SUB030": {
    "start_sec": 58.0,
    "end_sec": 60.0,
    "text": "帮我们处理工作"
  },
  "SUB031": {
    "start_sec": 60.0,
    "end_sec": 62.0,
    "text": "Clothbolt的最大优势"
  },
  "SUB032": {
    "start_sec": 62.0,
    "end_sec": 64.0,
    "text": "是可以接入各种聊天工具"
  },
  "SUB033": {
    "start_sec": 64.0,
    "end_sec": 66.0,
    "text": "也就是我们即使出门在外"
  },
  "SUB034": {
    "start_sec": 66.0,
    "end_sec": 68.0,
    "text": "手边没有电脑"
  },
  "SUB035": {
    "start_sec": 68.0,
    "end_sec": 70.0,
    "text": "只需要在聊天工具里面"
  },
  "SUB036": {
    "start_sec": 70.0,
    "end_sec": 72.0,
    "text": "给Clothbolt留个言"
  },
  "SUB037": {
    "start_sec": 72.0,
    "end_sec": 74.0,
    "text": "Clothbolt就能自动干活"
  },
  "SUB038": {
    "start_sec": 74.0,
    "end_sec": 76.0,
    "text": "还能把屏幕截图"
  },
  "SUB039": {
    "start_sec": 76.0,
    "end_sec": 78.0,
    "text": "执行过程等信息"
  },
  "SUB040": {
    "start_sec": 78.0,
    "end_sec": 80.0,
    "text": "实时同步过来"
  },
  "SUB041": {
    "start_sec": 80.0,
    "end_sec": 82.0,
    "text": "非常的方便"
  },
  "SUB042": {
    "start_sec": 82.0,
    "end_sec": 84.0,
    "text": "第二个优点是"
  },
  "SUB043": {
    "start_sec": 84.0,
    "end_sec": 86.0,
    "text": "Clothbolt自带了强大的定时任务系统"
  },
  "SUB044": {
    "start_sec": 86.0,
    "end_sec": 88.0,
    "text": "只需要用自然语言"
  },
  "SUB045": {
    "start_sec": 88.0,
    "end_sec": 90.0,
    "text": "就能创建定时任务"
  },
  "SUB046": {
    "start_sec": 90.0,
    "end_sec": 92.0,
    "text": "[00:01:11] 比如可以创建一个临时的提醒"
  },
  "SUB047": {
    "start_sec": 92.0,
    "end_sec": 94.0,
    "text": "还可以定时检查邮件箱"
  },
  "SUB048": {
    "start_sec": 94.0,
    "end_sec": 96.0,
    "text": "[00:01:15] 通知等等"
  },
  "SUB049": {
    "start_sec": 96.0,
    "end_sec": 98.0,
    "text": "[00:01:16] 它可以智能的判断"
  },
  "SUB050": {
    "start_sec": 98.0,
    "end_sec": 100.0,
    "text": "[00:01:17] 事情的紧急程度"
  },
  "SUB051": {
    "start_sec": 100.0,
    "end_sec": 102.0,
    "text": "[00:01:18] 选择是否用聊天工具"
  },
  "SUB052": {
    "start_sec": 102.0,
    "end_sec": 104.0,
    "text": "[00:01:20] 跟用户进行沟通"
  },
  "SUB053": {
    "start_sec": 104.0,
    "end_sec": 106.0,
    "text": "[00:01:21] 比起传统的指令"
  },
  "SUB054": {
    "start_sec": 106.0,
    "end_sec": 108.0,
    "text": "[00:01:23] 执行指令"
  },
  "SUB055": {
    "start_sec": 108.0,
    "end_sec": 110.0,
    "text": "[00:01:24] 执行这种固定的流程"
  },
  "SUB056": {
    "start_sec": 110.0,
    "end_sec": 112.0,
    "text": "Claude就具有了很强的主观能动性"
  },
  "SUB057": {
    "start_sec": 112.0,
    "end_sec": 114.0,
    "text": "它的第三个优点是具有长期记忆"
  },
  "SUB058": {
    "start_sec": 114.0,
    "end_sec": 116.0,
    "text": "[00:01:31] 可以把记忆作为文件"
  },
  "SUB059": {
    "start_sec": 116.0,
    "end_sec": 118.0,
    "text": "[00:01:32] 存储在本地"
  },
  "SUB060": {
    "start_sec": 118.0,
    "end_sec": 120.0,
    "text": "[00:01:33] 在日常的对话中"
  },
  "SUB061": {
    "start_sec": 120.0,
    "end_sec": 122.0,
    "text": "[00:01:35] 能够搜索"
  },
  "SUB062": {
    "start_sec": 122.0,
    "end_sec": 124.0,
    "text": "[00:01:35] 并且把相关的记忆"
  },
  "SUB063": {
    "start_sec": 124.0,
    "end_sec": 126.0,
    "text": "捞回上下文"
  },
  "SUB064": {
    "start_sec": 126.0,
    "end_sec": 128.0,
    "text": "[00:01:38] 随着日常使用"
  },
  "SUB065": {
    "start_sec": 128.0,
    "end_sec": 130.0,
    "text": "[00:01:39] 它还会主动去更新这些记忆文件"
  },
  "SUB066": {
    "start_sec": 130.0,
    "end_sec": 132.0,
    "text": "[00:01:42] 会有一种越用越聪明的感觉"
  },
  "SUB067": {
    "start_sec": 132.0,
    "end_sec": 134.0,
    "text": "[00:01:44] 好"
  },
  "SUB068": {
    "start_sec": 134.0,
    "end_sec": 136.0,
    "text": "[00:01:44] 我们现在本地把软件安装一下"
  },
  "SUB069": {
    "start_sec": 136.0,
    "end_sec": 138.0,
    "text": "任意一个能运行Node.js的环境"
  },
  "SUB070": {
    "start_sec": 138.0,
    "end_sec": 140.0,
    "text": "都可以部署Claude"
  },
  "SUB071": {
    "start_sec": 140.0,
    "end_sec": 142.0,
    "text": "我最推荐就是使用Mac"
  },
  "SUB072": {
    "start_sec": 142.0,
    "end_sec": 144.0,
    "text": "[00:01:54] 或者Linux系统的家庭服务器"
  },
  "SUB073": {
    "start_sec": 144.0,
    "end_sec": 146.0,
    "text": "现在最火的部署方案是使用Mac Mini"
  },
  "SUB074": {
    "start_sec": 146.0,
    "end_sec": 148.0,
    "text": "Mac Mini的最大好处"
  },
  "SUB075": {
    "start_sec": 148.0,
    "end_sec": 150.0,
    "text": "是Mac系统有不错的桌面环境"
  },
  "SUB076": {
    "start_sec": 150.0,
    "end_sec": 152.0,
    "text": "这样可以很方便的进行截图"
  },
  "SUB077": {
    "start_sec": 152.0,
    "end_sec": 154.0,
    "text": "操作流程图等等"
  },
  "SUB078": {
    "start_sec": 154.0,
    "end_sec": 156.0,
    "text": "第二点是功耗比较低"
  },
  "SUB079": {
    "start_sec": 156.0,
    "end_sec": 158.0,
    "text": "7×24小时运行比较省电"
  },
  "SUB080": {
    "start_sec": 158.0,
    "end_sec": 160.0,
    "text": "第三个优点是"
  },
  "SUB081": {
    "start_sec": 160.0,
    "end_sec": 162.0,
    "text": "Cloudbolt里面"
  },
  "SUB082": {
    "start_sec": 162.0,
    "end_sec": 164.0,
    "text": "许多Skills跟Mac生态是绑定的"
  },
  "SUB083": {
    "start_sec": 164.0,
    "end_sec": 166.0,
    "text": "没有Mac电脑的话"
  },
  "SUB084": {
    "start_sec": 166.0,
    "end_sec": 168.0,
    "text": "可以选择Linux操作系统"
  },
  "SUB085": {
    "start_sec": 168.0,
    "end_sec": 170.0,
    "text": "或者在Windows里面创建一个Linux的虚拟机"
  },
  "SUB086": {
    "start_sec": 170.0,
    "end_sec": 172.0,
    "text": "操作部署跟接下来是一样的"
  },
  "SUB087": {
    "start_sec": 172.0,
    "end_sec": 174.0,
    "text": "我选择的安装方式是Node.js"
  },
  "SUB088": {
    "start_sec": 174.0,
    "end_sec": 176.0,
    "text": "我们来到Node.js的官网"
  },
  "SUB089": {
    "start_sec": 176.0,
    "end_sec": 178.0,
    "text": "把第一个命令复制一下"
  },
  "SUB090": {
    "start_sec": 178.0,
    "end_sec": 180.0,
    "text": "然后打开终端执行一下"
  },
  "SUB091": {
    "start_sec": 180.0,
    "end_sec": 182.0,
    "text": "[00:02:30] 接着是第二个命令"
  },
  "SUB092": {
    "start_sec": 182.0,
    "end_sec": 184.0,
    "text": "[00:02:32] 第三个命令"
  },
  "SUB093": {
    "start_sec": 184.0,
    "end_sec": 186.0,
    "text": "[00:02:34] 这样Node.js就安装完成了"
  },
  "SUB094": {
    "start_sec": 186.0,
    "end_sec": 188.0,
    "text": "下一步我们来到Clothbolt的官网"
  },
  "SUB095": {
    "start_sec": 188.0,
    "end_sec": 190.0,
    "text": "在这里有一个一键安装命令"
  },
  "SUB096": {
    "start_sec": 190.0,
    "end_sec": 192.0,
    "text": "如果我们使用官网上的一键安装命令的话"
  },
  "SUB097": {
    "start_sec": 192.0,
    "end_sec": 194.0,
    "text": "[00:02:43] 注意要区分现在软件的名字"
  },
  "SUB098": {
    "start_sec": 194.0,
    "end_sec": 196.0,
    "text": "比如现在叫OpenCloth"
  },
  "SUB099": {
    "start_sec": 196.0,
    "end_sec": 198.0,
    "text": "[00:02:47] 后续所有操作的命令"
  },
  "SUB100": {
    "start_sec": 198.0,
    "end_sec": 200.0,
    "text": "都应该是OpenCloth开头了"
  },
  "SUB101": {
    "start_sec": 200.0,
    "end_sec": 202.0,
    "text": "[00:02:50] 这里我选择NPM的安装方式"
  },
  "SUB102": {
    "start_sec": 202.0,
    "end_sec": 204.0,
    "text": "[00:02:52] 我们看到NPM这里"
  },
  "SUB103": {
    "start_sec": 204.0,
    "end_sec": 206.0,
    "text": "命令还是叫Clothbolt"
  },
  "SUB104": {
    "start_sec": 206.0,
    "end_sec": 208.0,
    "text": "[00:02:56] 所以后续我输入的命令"
  },
  "SUB105": {
    "start_sec": 208.0,
    "end_sec": 210.0,
    "text": "都应该还是Clothbolt开头了"
  },
  "SUB106": {
    "start_sec": 210.0,
    "end_sec": 212.0,
    "text": "[00:02:59] 这样我把这个命令复制一下"
  },
  "SUB107": {
    "start_sec": 212.0,
    "end_sec": 214.0,
    "text": "粘贴到命令行窗口"
  },
  "SUB108": {
    "start_sec": 214.0,
    "end_sec": 216.0,
    "text": "[00:03:02] 执行一下"
  },
  "SUB109": {
    "start_sec": 216.0,
    "end_sec": 218.0,
    "text": "[00:03:03] 安装完成我们输入命令"
  },
  "SUB110": {
    "start_sec": 218.0,
    "end_sec": 220.0,
    "text": "Clothbolt onboard来进行初始化"
  },
  "SUB111": {
    "start_sec": 220.0,
    "end_sec": 222.0,
    "text": "[00:03:07] 第一步先配置AI模型"
  },
  "SUB112": {
    "start_sec": 222.0,
    "end_sec": 224.0,
    "text": "[00:03:09] 因为我有OpenAI的Plus订阅"
  },
  "SUB113": {
    "start_sec": 224.0,
    "end_sec": 226.0,
    "text": "[00:03:11] 所以这里我选择OpenAI"
  },
  "SUB114": {
    "start_sec": 226.0,
    "end_sec": 228.0,
    "text": "[00:03:13] 当然下面也有很多"
  },
  "SUB115": {
    "start_sec": 228.0,
    "end_sec": 230.0,
    "text": "[00:03:14] 不错的国产模型可以选择"
  },
  "SUB116": {
    "start_sec": 230.0,
    "end_sec": 232.0,
    "text": "[00:03:16] 视频的后半段"
  },
  "SUB117": {
    "start_sec": 232.0,
    "end_sec": 234.0,
    "text": "[00:03:17] 我们再来配置使用国产模型"
  },
  "SUB118": {
    "start_sec": 234.0,
    "end_sec": 236.0,
    "text": "[00:03:19] 选择OpenAI以后再选择"
  },
  "SUB119": {
    "start_sec": 236.0,
    "end_sec": 238.0,
    "text": "[00:03:21] 第二个"
  },
  "SUB120": {
    "start_sec": 238.0,
    "end_sec": 240.0,
    "text": "[00:03:36] 我们打开手机上的WhatsApp"
  },
  "SUB121": {
    "start_sec": 240.0,
    "end_sec": 242.0,
    "text": "右上角三个点"
  },
  "SUB122": {
    "start_sec": 242.0,
    "end_sec": 244.0,
    "text": "以关联设备"
  },
  "SUB123": {
    "start_sec": 244.0,
    "end_sec": 246.0,
    "text": "关联新设备"
  },
  "SUB124": {
    "start_sec": 246.0,
    "end_sec": 248.0,
    "text": "扫一下屏幕上的二维码"
  },
  "SUB125": {
    "start_sec": 248.0,
    "end_sec": 250.0,
    "text": "这样就绑定完成"
  },
  "SUB126": {
    "start_sec": 250.0,
    "end_sec": 252.0,
    "text": "接下来选择预装的Skills"
  },
  "SUB127": {
    "start_sec": 252.0,
    "end_sec": 254.0,
    "text": "按空格键打上勾即选中"
  },
  "SUB128": {
    "start_sec": 254.0,
    "end_sec": 256.0,
    "text": "这里可以按需进行选择安装"
  },
  "SUB129": {
    "start_sec": 256.0,
    "end_sec": 258.0,
    "text": "下面的这些EPSK可以全部选择跳过"
  },
  "SUB130": {
    "start_sec": 258.0,
    "end_sec": 260.0,
    "text": "然后AI会询问我们一些关于人设方面的问题"
  },
  "SUB131": {
    "start_sec": 260.0,
    "end_sec": 262.0,
    "text": "我们回答一下"
  },
  "SUB132": {
    "start_sec": 262.0,
    "end_sec": 264.0,
    "text": "这样就配置完成"
  },
  "SUB133": {
    "start_sec": 264.0,
    "end_sec": 266.0,
    "text": "我说你可以给我的聊天工具发一个消息"
  },
  "SUB134": {
    "start_sec": 266.0,
    "end_sec": 268.0,
    "text": "我们看到手机上收到了消息"
  },
  "SUB135": {
    "start_sec": 268.0,
    "end_sec": 270.0,
    "text": "这样就完全配置成功了"
  },
  "SUB136": {
    "start_sec": 270.0,
    "end_sec": 272.0,
    "text": "[00:04:08] 我们先来介绍几个基础命令的使用"
  },
  "SUB137": {
    "start_sec": 272.0,
    "end_sec": 274.0,
    "text": "输入命令Clothbolt Gateway"
  },
  "SUB138": {
    "start_sec": 274.0,
    "end_sec": 276.0,
    "text": "[00:04:12] 这个是启动主程序"
  },
  "SUB139": {
    "start_sec": 276.0,
    "end_sec": 278.0,
    "text": "我们可以通过关闭控制台"
  },
  "SUB140": {
    "start_sec": 278.0,
    "end_sec": 280.0,
    "text": "[00:04:15] 来停止Clothbolt的运行"
  },
  "SUB141": {
    "start_sec": 280.0,
    "end_sec": 282.0,
    "text": "[00:04:17] 在Clothbolt后台运行的时候"
  },
  "SUB142": {
    "start_sec": 282.0,
    "end_sec": 284.0,
    "text": "[00:04:19] 我们可以新开一个窗口"
  },
  "SUB143": {
    "start_sec": 284.0,
    "end_sec": 286.0,
    "text": "[00:04:21] 输入命令Clothbolt TUI"
  },
  "SUB144": {
    "start_sec": 286.0,
    "end_sec": 288.0,
    "text": "就可以进入这个控制台的对话界面"
  },
  "SUB145": {
    "start_sec": 288.0,
    "end_sec": 290.0,
    "text": "[00:04:25] 输入命令Clothbolt Dashboard"
  },
  "SUB146": {
    "start_sec": 290.0,
    "end_sec": 292.0,
    "text": "可以进入一个网页版的控制台"
  },
  "SUB147": {
    "start_sec": 292.0,
    "end_sec": 294.0,
    "text": "[00:04:30] 在这里可以进行基础的对话"
  },
  "SUB148": {
    "start_sec": 294.0,
    "end_sec": 296.0,
    "text": "[00:04:32] 上面还有很多配置"
