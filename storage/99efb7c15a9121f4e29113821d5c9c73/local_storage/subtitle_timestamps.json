  "SUB296": {
    "start_sec": 590.0,
    "end_sec": 592.0,
    "text": "我们点击这个安装按钮"
  },
  "SUB297": {
    "start_sec": 592.0,
    "end_sec": 594.0,
    "text": "这里要提醒一下大家"
