{
  "SUB001": {
    "start_sec": 0.0,
    "end_sec": 1.0,
    "text": "CloudBot一夜爆火"
  },
  "SUB002": {
    "start_sec": 1.0,
    "end_sec": 4.0,
    "text": "这是一个运行在本地电脑的开源AI助理"
  },
  "SUB003": {
    "start_sec": 4.0,
    "end_sec": 7.0,
    "text": "短短几天内GitHub Star数量直线拉升"
  },
  "SUB004": {
    "start_sec": 7.0,
    "end_sec": 8.0,
    "text": "已经超过了12万"
  },
  "SUB005": {
    "start_sec": 8.0,
    "end_sec": 11.0,
    "text": "本期视频我们带来一个CloudBot的全面攻略"
  },
  "SUB006": {
    "start_sec": 11.0,
    "end_sec": 15.0,
    "text": "看看CloudBot比起其他的AI agent有什么特色"
  },
  "SUB007": {
    "start_sec": 15.0,
    "end_sec": 17.0,
    "text": "我准备了十几个案例的玩法大全"
  },
  "SUB008": {
    "start_sec": 17.0,
    "end_sec": 18.0,
    "text": "还会介绍一个"
  },
  "SUB009": {
    "start_sec": 18.0,
    "end_sec": 20.0,
    "text": "接入非输加国产模型的方案"
  },
  "SUB010": {
    "start_sec": 20.0,
    "end_sec": 24.0,
    "text": "让CloudBot在国内网络也能顺畅使用"
  },
  "SUB011": {
    "start_sec": 24.0,
    "end_sec": 26.0,
    "text": "视频开始之前先插入一个小插曲"
  },
  "SUB012": {
    "start_sec": 26.0,
    "end_sec": 29.0,
    "text": "由于CloudBot受到安苏尔佩克法务团队的压力"
  },
  "SUB013": {
    "start_sec": 29.0,
    "end_sec": 32.0,
    "text": "CloudBot先是改名成了MultBot"
  },
  "SUB014": {
    "start_sec": 32.0,
    "end_sec": 34.0,
    "text": "现在又改名成了OpenCloud"
  },
  "SUB015": {
    "start_sec": 34.0,
    "end_sec": 35.0,
    "text": "啪啪瞎做视频的速度"
  },
  "SUB016": {
    "start_sec": 35.0,
    "end_sec": 37.0,
    "text": "还赶不上他改名的速度"
  },
  "SUB017": {
    "start_sec": 37.0,
    "end_sec": 38.0,
    "text": "所以本期视频"
  },
  "SUB018": {
    "start_sec": 38.0,
    "end_sec": 40.0,
    "text": "我们还是统一叫他最开始的名字"
  },
  "SUB019": {
    "start_sec": 40.0,
    "end_sec": 41.0,
    "text": "CloudBot"
  },
  "SUB020": {
    "start_sec": 41.0,
    "end_sec": 44.0,
    "text": "CloudBot功能跟CloudCode和OpenCode都有点像"
  },
  "SUB021": {
    "start_sec": 44.0,
    "end_sec": 46.0,
    "text": "都可以处理文件"
  },
  "SUB022": {
    "start_sec": 46.0,
    "end_sec": 46.0,
    "text": "编码"
  },
  "SUB023": {
    "start_sec": 46.0,
    "end_sec": 47.0,
    "text": "调用skills"
  },
  "SUB024": {
    "start_sec": 47.0,
    "end_sec": 49.0,
    "text": "mcp等等帮我们处理工作"
  },
  "SUB025": {
    "start_sec": 49.0,
    "end_sec": 51.0,
    "text": "CloudBot的最大优势是"
  },
  "SUB026": {
    "start_sec": 51.0,
    "end_sec": 53.0,
    "text": "可以接入各种聊天工具"
  },
  "SUB027": {
    "start_sec": 53.0,
    "end_sec": 54.0,
    "text": "也就是我们即使出门在外"
  },
  "SUB028": {
    "start_sec": 54.0,
    "end_sec": 55.0,
    "text": "手边没有电脑"
  },
  "SUB029": {
    "start_sec": 55.0,
    "end_sec": 57.0,
    "text": "只需要在聊天工具里面"
  },
  "SUB030": {
    "start_sec": 57.0,
    "end_sec": 58.0,
    "text": "给CloudBot留个言"
  },
  "SUB031": {
    "start_sec": 58.0,
    "end_sec": 60.0,
    "text": "CloudBot就能自动干活"
  },
  "SUB032": {
    "start_sec": 60.0,
    "end_sec": 62.0,
    "text": "还能把屏幕截图"
  },
  "SUB033": {
    "start_sec": 62.0,
    "end_sec": 63.0,
    "text": "执行过程等信息"
  },
  "SUB034": {
    "start_sec": 63.0,
    "end_sec": 64.0,
    "text": "实时同步过来"
  },
  "SUB035": {
    "start_sec": 64.0,
    "end_sec": 65.0,
    "text": "非常的方便"
  },
  "SUB036": {
    "start_sec": 65.0,
    "end_sec": 66.0,
    "text": "第二个优点是"
  },
  "SUB037": {
    "start_sec": 66.0,
    "end_sec": 69.0,
    "text": "CloudBot自带了强大的定时器系统"
  },
  "SUB038": {
    "start_sec": 69.0,
    "end_sec": 71.0,
    "text": "只需要用自然语言就能创建定时器"
  },
  "SUB039": {
    "start_sec": 71.0,
    "end_sec": 73.0,
    "text": "比如可以创建一个临时的提醒"
  },
  "SUB040": {
    "start_sec": 73.0,
    "end_sec": 75.0,
    "text": "还可以定时检查收件箱"
  },
  "SUB041": {
    "start_sec": 75.0,
    "end_sec": 76.0,
    "text": "通知等等"
  },
  "SUB042": {
    "start_sec": 76.0,
    "end_sec": 78.0,
    "text": "它可以智能的判断事情的紧急程度"
  },
  "SUB043": {
    "start_sec": 78.0,
    "end_sec": 80.0,
    "text": "选择是否用聊天工具"
  },
  "SUB044": {
    "start_sec": 80.0,
    "end_sec": 81.0,
    "text": "跟用户进行沟通"
  },
  "SUB045": {
    "start_sec": 81.0,
    "end_sec": 83.0,
    "text": "比起传统的指令"
  },
  "SUB046": {
    "start_sec": 83.0,
    "end_sec": 85.0,
    "text": "执行指令执行这种固定的流程"
  },
  "SUB047": {
    "start_sec": 85.0,
    "end_sec": 88.0,
    "text": "CloudBot就具有了很强的主观能动性"
  },
  "SUB048": {
    "start_sec": 88.0,
    "end_sec": 91.0,
    "text": "它的第三个优点是具有长期记忆"
  },
  "SUB049": {
    "start_sec": 91.0,
    "end_sec": 93.0,
    "text": "可以把记忆作为文件存储在本地"
  },
  "SUB050": {
    "start_sec": 93.0,
    "end_sec": 95.0,
    "text": "在日常的对话中能够搜索"
  },
  "SUB051": {
    "start_sec": 95.0,
    "end_sec": 98.0,
    "text": "并且把相关的记忆捞回上下文"
  },
  "SUB052": {
    "start_sec": 98.0,
    "end_sec": 99.0,
    "text": "随着日常使用"
  },
  "SUB053": {
    "start_sec": 99.0,
    "end_sec": 102.0,
    "text": "它还会主动去更新这些记忆文件"
  },
  "SUB054": {
    "start_sec": 102.0,
    "end_sec": 104.0,
    "text": "会有一种越用越聪明的感觉"
  },
  "SUB055": {
    "start_sec": 104.0,
    "end_sec": 106.0,
    "text": "好我们先在本地把软件安装一下"
  },
  "SUB056": {
    "start_sec": 108.0,
    "end_sec": 110.0,
    "text": "任意一个能运行JS的环境"
  },
  "SUB057": {
    "start_sec": 110.0,
    "end_sec": 112.0,
    "text": "都可以部署CloudBot"
  },
  "SUB058": {
    "start_sec": 112.0,
    "end_sec": 114.0,
    "text": "我最推荐就是使用Mac"
  },
  "SUB059": {
    "start_sec": 114.0,
    "end_sec": 116.0,
    "text": "或者Linux系统的家庭服务器"
  },
  "SUB060": {
    "start_sec": 116.0,
    "end_sec": 119.0,
    "text": "现在最火的部署方案是使用Mac mini"
  },
  "SUB061": {
    "start_sec": 119.0,
    "end_sec": 120.0,
    "text": "Mac mini的最大好处是"
  },
  "SUB062": {
    "start_sec": 120.0,
    "end_sec": 122.0,
    "text": "Mac系统有不错的桌面环境"
  },
  "SUB063": {
    "start_sec": 122.0,
    "end_sec": 124.0,
    "text": "这样可以很方便地进行截图"
  },
  "SUB064": {
    "start_sec": 124.0,
    "end_sec": 126.0,
    "text": "操作浏览器等等"
  },
  "SUB065": {
    "start_sec": 126.0,
    "end_sec": 127.0,
    "text": "第二点是功耗比较低"
  },
  "SUB066": {
    "start_sec": 127.0,
    "end_sec": 130.0,
    "text": "7x24小时运行比较省电"
  },
  "SUB067": {
    "start_sec": 130.0,
    "end_sec": 131.0,
    "text": "第三个优点是"
  },
  "SUB068": {
    "start_sec": 131.0,
    "end_sec": 133.0,
    "text": "CloudBot里面许多skills"
  },
  "SUB069": {
    "start_sec": 133.0,
    "end_sec": 135.0,
    "text": "跟Mac生态是绑定的"
  },
  "SUB070": {
    "start_sec": 135.0,
    "end_sec": 136.0,
    "text": "没有Mac电脑的话"
  },
  "SUB071": {
    "start_sec": 136.0,
    "end_sec": 138.0,
    "text": "可以选择Linux操作系统"
  },
  "SUB072": {
    "start_sec": 138.0,
    "end_sec": 139.0,
    "text": "或者在Windows里面"
  },
  "SUB073": {
    "start_sec": 139.0,
    "end_sec": 141.0,
    "text": "创建一个Linux虚拟机"
  },
  "SUB074": {
    "start_sec": 141.0,
    "end_sec": 143.0,
    "text": "操作步骤跟接下来是一样的"
  },
  "SUB075": {
    "start_sec": 143.0,
    "end_sec": 145.0,
    "text": "我选择的安装方式是NodeJS"
  },
  "SUB076": {
    "start_sec": 145.0,
    "end_sec": 147.0,
    "text": "我们来到NodeJS的官网"
  },
  "SUB077": {
    "start_sec": 147.0,
    "end_sec": 148.0,
    "text": "把第一个命令复制一下"
  },
  "SUB078": {
    "start_sec": 148.0,
    "end_sec": 150.0,
    "text": "然后打开终端执行一下"
  },
  "SUB079": {
    "start_sec": 150.0,
    "end_sec": 152.0,
    "text": "接着是第二个命令"
  },
  "SUB080": {
    "start_sec": 152.0,
    "end_sec": 153.0,
    "text": "第三个命令"
  },
  "SUB081": {
    "start_sec": 154.0,
    "end_sec": 156.0,
    "text": "这样NodeJS就安装完成了"
  },
  "SUB082": {
    "start_sec": 156.0,
    "end_sec": 159.0,
    "text": "下一步我们来到CloudBot的官网"
  },
  "SUB083": {
    "start_sec": 159.0,
    "end_sec": 161.0,
    "text": "在这里有一个一键安装命令"
  },
  "SUB084": {
    "start_sec": 161.0,
    "end_sec": 162.0,
    "text": "如果我们使用官网上的"
  },
  "SUB085": {
    "start_sec": 162.0,
    "end_sec": 163.0,
    "text": "一键安装命令的话"
  },
  "SUB086": {
    "start_sec": 163.0,
    "end_sec": 166.0,
    "text": "注意要区分现在软件的名字"
  },
  "SUB087": {
    "start_sec": 166.0,
    "end_sec": 167.0,
    "text": "比如现在叫OpenCloud"
  },
  "SUB088": {
    "start_sec": 167.0,
    "end_sec": 169.0,
    "text": "后续所有操作的命令"
  },
  "SUB089": {
    "start_sec": 169.0,
    "end_sec": 170.0,
    "text": "都应该是OpenCloud开头了"
  },
  "SUB090": {
    "start_sec": 170.0,
    "end_sec": 172.0,
    "text": "这里我选择NPM的安装方式"
  },
  "SUB091": {
    "start_sec": 172.0,
    "end_sec": 174.0,
    "text": "我们看到NPM这里"
  },
  "SUB092": {
    "start_sec": 174.0,
    "end_sec": 176.0,
    "text": "命令还是叫CloudBot"
  },
  "SUB093": {
    "start_sec": 176.0,
    "end_sec": 177.0,
    "text": "所以后续我输入的命令"
  },
  "SUB094": {
    "start_sec": 177.0,
    "end_sec": 179.0,
    "text": "都应该还是CloudBot开头了"
  },
  "SUB095": {
    "start_sec": 179.0,
    "end_sec": 181.0,
    "text": "这样我把这个命令复制一下"
  },
  "SUB096": {
    "start_sec": 181.0,
    "end_sec": 183.0,
    "text": "粘贴到命令行窗口执行一下"
  },
  "SUB097": {
    "start_sec": 183.0,
    "end_sec": 185.0,
    "text": "安装完成我们输入命令"
  },
  "SUB098": {
    "start_sec": 185.0,
    "end_sec": 187.0,
    "text": "CloudBot Onboard来进行初始化"
  },
  "SUB099": {
    "start_sec": 187.0,
    "end_sec": 189.0,
    "text": "第一步先配置AI模型"
  },
  "SUB100": {
    "start_sec": 189.0,
    "end_sec": 191.0,
    "text": "因为我有OpenAI的Plus订阅"
  },
  "SUB101": {
    "start_sec": 191.0,
    "end_sec": 193.0,
    "text": "所以这里我选择OpenAI"
  },
  "SUB102": {
    "start_sec": 193.0,
    "end_sec": 195.0,
    "text": "当然下面也有很多不错的"
  },
  "SUB103": {
    "start_sec": 195.0,
