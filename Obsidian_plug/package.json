{
  "name": "phase2b-structured-rewrite",
  "version": "0.1.0",
  "private": true,
  "description": "Obsidian 插件：调用现有 /phase2b/structured-markdown 接口对选区进行结构化改写。",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "sync:vault": "powershell.exe -ExecutionPolicy Bypass -File .\\sync-to-vault.ps1",
    "sync:vault:skip-build": "powershell.exe -ExecutionPolicy Bypass -File .\\sync-to-vault.ps1 -SkipBuild"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "esbuild": "^0.25.1",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.2"
  }
}