# Copy to repository root as .env before docker compose up -d
# As of 2026-03-07, all non-secret values below match the author's current best-effect local profile.
# In normal use, users only need to fill:
# 1) DEEPSEEK_API_KEY
# 2) DASHSCOPE_API_KEY

# Required: DeepSeek (text pipeline)
DEEPSEEK_API_KEY=

# DeepSeek production concurrency profile (from 2026-02-16 core benchmark)
MODULE2_DEEPSEEK_CONCURRENCY_INITIAL=56
MODULE2_DEEPSEEK_CONCURRENCY_MIN=8
MODULE2_DEEPSEEK_CONCURRENCY_MAX=64
MODULE2_DEEPSEEK_CONCURRENCY_INCREASE_STEP=1
MODULE2_DEEPSEEK_CONCURRENCY_WINDOW_SIZE=30
MODULE2_SEMANTIC_SEGMENT_BATCH_MAX_CONCURRENCY=48
MODULE2_MARKDOWN_SECTION_MAX_INFLIGHT=56
MODULE2_KC_MULTI_CHUNK_MAX_INFLIGHT=48

# Required: DashScope (VL video analysis)
DASHSCOPE_API_KEY=

# Optional: ERNIE Vision (image validation, disabled by default)
VISION_AI_BEARER_TOKEN=